# UAT Environment — copy to the UAT server at:
# /home/u686730471/domains/uat.caveoinfosystems.com/public_html/.builds/config/.env
#
# Fill in every value before running deploy-uat.mjs

# ── Database ──────────────────────────────────────────────────────────────────
# UAT database created in hPanel → Databases → MySQL
DATABASE_URL="mysql://u686730471_uatuser:C%40veo%402026@127.0.0.1:3306/u686730471_Caveo_UAT"

# ── NextAuth ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="https://uat.caveoinfosystems.com"
NEXTAUTH_SECRET="GENERATE_WITH: openssl rand -base64 32"

# ── Microsoft Entra ID (same app registration as prod, or a separate UAT one) ─
AUTH_MICROSOFT_ENTRA_ID_ID="YOUR_AZURE_CLIENT_ID"
AUTH_MICROSOFT_ENTRA_ID_SECRET="YOUR_AZURE_CLIENT_SECRET"
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID="YOUR_AZURE_TENANT_ID"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="production"
NEXT_TELEMETRY_DISABLED="1"
