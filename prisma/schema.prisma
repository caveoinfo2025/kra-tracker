}

model SessionPolicy {
  id                    Int      @id @default(autoincrement())
  companyId             Int?
  idleTimeoutMinutes    Int      @default(480)
  maxSessionHours       Int      @default(8)
  allowConcurrentLogin  Boolean  @default(true)
  maxConcurrentSessions Int      @default(3)
  rememberMeAllowed     Boolean  @default(true)
  status                String   @default("ACTIVE")
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([companyId])
  @@map("session_policy")
}

model AccessRestrictionPolicy {
  id                      Int      @id @default(autoincrement())
  companyId               Int?
  ipRestrictionEnabled    Boolean  @default(false)
  allowedIpJson           String   @default("[]") @db.Text
  businessHourRestriction Boolean  @default(false)
  allowedHoursJson        String   @default("{\"start\":\"09:00\",\"end\":\"18:00\",\"days\":[1,2,3,4,5]}") @db.Text
  locationRestrictionJson String   @default("{}") @db.Text
  status                  String   @default("ACTIVE")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
  @@map("access_restriction_policy")
}

model DataProtectionPolicy {
  id                     Int      @id @default(autoincrement())
  companyId              Int?
  exportLimit            Int      @default(1000)
  exportApprovalRequired Boolean  @default(false)
  downloadRestriction    Boolean  @default(false)
  sensitiveFieldsJson    String   @default("[]") @db.Text
  maskingRulesJson       String   @default("[]") @db.Text
  status                 String   @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@index([companyId])
  @@map("data_protection_policy")
}

model SecurityEventLog {
  id           Int      @id @default(autoincrement())
  userId       Int?
  eventType    String
  metadataJson String   @default("{}") @db.Text
  ipAddress    String?
  userAgent    String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("security_event_log")
}

