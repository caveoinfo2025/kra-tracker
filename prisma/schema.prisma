// Гў"в‚¬Гў"в‚¬ 26. MasterCategory Гўв‚¬" groups master definitions by domain Гў"в‚¬Гў"в‚¬
model MasterCategory {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  definitions MasterDefinition[]

  @@map("master_category")
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 27. MasterDefinition Гўв‚¬" defines a named master (e.g. OEM, Industry) Гў"в‚¬Гў"в‚¬
model MasterDefinition {
  id                   Int     @id @default(autoincrement())
  categoryId           Int
  name                 String
  code                 String  @unique
  description          String  @default("") @db.Text
  allowCompanyOverride Boolean @default(true)
  allowBranchOverride  Boolean @default(false)
  requiresApproval     Boolean @default(false)
  status               String  @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category        MasterCategory         @relation(fields: [categoryId], references: [id])
  values          MasterValue[]
  validationRules MasterValidationRule[]

  @@map("master_definition")
  @@index([categoryId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 28. MasterValue Гўв‚¬" a single item inside a master Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
// code is unique per definition; parentId allows hierarchy (sub-categories)
model MasterValue {
  id                 Int     @id @default(autoincrement())
  masterDefinitionId Int
  parentId           Int?
  value              String
  code               String
  description        String  @default("") @db.Text
  metadataJson       String? @db.Text
  sortOrder          Int     @default(0)
  status             String  @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  definition MasterDefinition @relation(fields: [masterDefinitionId], references: [id], onDelete: Cascade)
  parent     MasterValue?     @relation("MasterValueParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   MasterValue[]    @relation("MasterValueParent")
  overrides  MasterOverride[]

  @@map("master_value")
  @@unique([masterDefinitionId, code])
  @@index([masterDefinitionId])
  @@index([parentId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 29. MasterOverride Гўв‚¬" company / branch level customisation Гў"в‚¬Гў"в‚¬
// scopeType: COMPANY | BRANCH
model MasterOverride {
  id            Int     @id @default(autoincrement())
  masterValueId Int
  scopeType     String  // COMPANY | BRANCH
  scopeId       Int
  customValue   String  @default("")
  isEnabled     Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  masterValue MasterValue @relation(fields: [masterValueId], references: [id], onDelete: Cascade)

  @@map("master_override")
  @@unique([masterValueId, scopeType, scopeId])
  @@index([masterValueId])
  @@index([scopeType, scopeId])
}

// Гў"в‚¬Гў"в‚¬ 30. MasterValidationRule Гўв‚¬" links a master to a Policy Engine rule Гў"в‚¬Гў"в‚¬
model MasterValidationRule {
  id                 Int     @id @default(autoincrement())
  masterDefinitionId Int
  policyId           Int?
  ruleName           String
  isActive           Boolean @default(true)

  definition MasterDefinition @relation(fields: [masterDefinitionId], references: [id], onDelete: Cascade)

  @@map("master_validation_rule")
  @@index([masterDefinitionId])
  @@index([policyId])
}

// Гў"в‚¬Гў"в‚¬ 31. MasterAudit Гўв‚¬" change trail for all master operations Гў"в‚¬Гў"в‚¬
// masterType: DEFINITION | VALUE | OVERRIDE | POLICY
model MasterAudit {
  id          Int      @id @default(autoincrement())
  masterId    Int
  masterType  String
  action      String   // CREATED | UPDATED | STATUS_CHANGED | OVERRIDE_ADDED | VALUE_IMPORTED
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  performer Employee @relation("MasterAuditPerformedBy", fields: [performedBy], references: [id])

  @@map("master_audit")
  @@index([masterId, masterType])
  @@index([performedBy])
  @@index([createdAt])
}

// Гў"в‚¬Гў"в‚¬ 32. CustomerPolicy Гўв‚¬" governance rules per company / customer type Гў"в‚¬Гў"в‚¬
model CustomerPolicy {
  id                     Int     @id @default(autoincrement())
  companyId              Int?
  customerType           String  @default("ALL")
  gstRequired            Boolean @default(true)
  panRequired            Boolean @default(false)
  duplicateThreshold     Int     @default(80)
  creditApprovalRequired Boolean @default(false)
  status                 String  @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("customer_policy")
  @@index([companyId])
  @@index([customerType])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 33. VendorPolicy Гўв‚¬" governance rules per company Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model VendorPolicy {
  id                       Int     @id @default(autoincrement())
  companyId                Int?
  gstRequired              Boolean @default(true)
  panRequired              Boolean @default(false)
  bankVerificationRequired Boolean @default(false)
  approvalRequired         Boolean @default(true)
  status                   String  @default("ACTIVE")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("vendor_policy")
  @@index([companyId])
  @@index([status])
}

// в”Ђв”Ђ 34. PipelineDefinition вЂ” named sales process with ordered stages в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Multiple pipelines can coexist (e.g. "Enterprise Sales", "Renewal Pipeline").
// isDefault=true pipeline is used when no pipeline is explicitly selected.
model PipelineDefinition {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  isDefault   Boolean  @default(false)
  status      String   @default("active") // active|archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages PipelineStage[]

  @@map("pipeline_definition")
  @@index([companyId])
  @@index([status])
}

// в”Ђв”Ђ 35. PipelineStage вЂ” one stage inside a PipelineDefinition в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// stageCode links back to OPP_STAGES for backward compat with existing CRM.
// stageType: OPEN | WON | LOST
// mandatoryFieldsJson: JSON array of field names, e.g. ["amount","expectedClosureDate"]
model PipelineStage {
  id                  Int                @id @default(autoincrement())
  pipelineId          Int
  pipeline            PipelineDefinition @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageName           String
  stageCode           String
  sequence            Int
  probability         Int                @default(50)
  stageType           String             @default("OPEN") // OPEN|WON|LOST
  requiresApproval    Boolean            @default(false)
  mandatoryFieldsJson String             @default("[]") @db.Text
  entryRuleId         Int?
  exitRuleId          Int?
  status              String             @default("active")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("pipeline_stage")
  @@index([pipelineId])
  @@index([pipelineId, sequence])
}

// в”Ђв”Ђ 36. Territory вЂ” named geographic/segment territory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
model Territory {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  name        String
  description String   @default("") @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules TerritoryRule[]

  @@map("territory")
  @@index([companyId])
  @@index([status])
}

// в”Ђв”Ђ 37. TerritoryRule вЂ” one condition line inside a Territory в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// conditionJson: {field:"state",operator:"eq",value:"Tamil Nadu"}
model TerritoryRule {
  id            Int       @id @default(autoincrement())
  territoryId   Int
  territory     Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  conditionJson String    @db.Text
  createdAt     DateTime  @default(now())

  @@map("territory_rule")
  @@index([territoryId])
}

// в”Ђв”Ђ 38. AccountAssignmentRule вЂ” priority-ordered assignment routing в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// assignToType: USER | TEAM | ROLE | QUEUE
// conditionJson: {and:[{field,operator,value},...]}
model AccountAssignmentRule {
  id            Int      @id @default(autoincrement())
  name          String
  priority      Int      @default(10)
  conditionJson String   @db.Text
  assignToType  String   // USER|TEAM|ROLE|QUEUE
  assignToId    Int?
  assignToName  String   @default("")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("account_assignment_rule")
  @@index([status, priority])
}

// в”Ђв”Ђ 39. CRMAutomationRule вЂ” event-driven no-code automation в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// event: LEAD_CREATED | LEAD_CONVERTED | OPPORTUNITY_CREATED | STAGE_CHANGED |
//        DEAL_WON | DEAL_LOST | NO_ACTIVITY | RENEWAL_DUE
// actionJson: {type:"CREATE_TASK",params:{title,daysFromNow,assignToType}}
model CRMAutomationRule {
  id            Int      @id @default(autoincrement())
  name          String
  event         String
  conditionJson String   @default("{}") @db.Text
  actionJson    String   @db.Text
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("crm_automation_rule")
  @@index([event, status])
}

// в”Ђв”Ђ 40. SLARule вЂ” response / follow-up time targets в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// module: CRM | SUPPORT | FINANCE
// event:  LEAD_RESPONSE | OPPORTUNITY_FOLLOW_UP | PROPOSAL_DUE | etc.
model SLARule {
  id                 Int      @id @default(autoincrement())
  module             String
  event              String
  label              String   @default("")
  durationHours      Int
  warningHours       Int      @default(0) // 0 = warn at 80% of durationHours
  escalationPolicyId Int?
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("sla_rule")
  @@index([module, event])
  @@index([status])
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Phase 10: Enterprise Performance Management Engine
// 9 models: PerformancePeriod, KRAMetric, KRATemplate, KRATemplateItem,
// EmployeeTarget, TeamTarget, KRAAchievement, PerformanceReview, PerformanceAudit
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

model PerformancePeriod {
  id            Int      @id @default(autoincrement())
  companyId     Int?
  name          String
  financialYear String   @default("")
  periodType    String   @default("YEARLY")
  startDate     DateTime
  endDate       DateTime
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employeeTargets EmployeeTarget[]
  teamTargets     TeamTarget[]

  @@index([companyId])
  @@index([periodType])
  @@index([status])
  @@index([financialYear])
  @@map("performance_period")
}

model KRAMetric {
  id                Int      @id @default(autoincrement())
  companyId         Int?
  name              String
  code              String   @unique
  description       String   @default("") @db.Text
  metricType        String   @default("CUSTOM")
  calculationSource String   @default("MANUAL")
  formulaJson       String   @default("") @db.Text
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  templateItems KRATemplateItem[]
  achievements  KRAAchievement[]

  @@index([companyId])
  @@index([metricType])
  @@index([status])
  @@map("kra_metric")
}

model KRATemplate {
  id           Int      @id @default(autoincrement())
  companyId    Int?
  name         String
  description  String   @default("") @db.Text
  roleId       Int?
  departmentId Int?
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items KRATemplateItem[]

  @@index([companyId])
  @@index([roleId])
  @@index([departmentId])
  @@index([status])
  @@map("kra_template")
}

model KRATemplateItem {
  id             Int         @id @default(autoincrement())
  template       KRATemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId     Int
  metric         KRAMetric   @relation(fields: [metricId], references: [id], onDelete: Restrict)
  metricId       Int
  weightage      Float       @default(0)
  targetType     String      @default("AMOUNT")
  minimumTarget  Float       @default(0)
  expectedTarget Float       @default(0)
  stretchTarget  Float       @default(0)
  sortOrder      Int         @default(0)
  status         String      @default("active")

  @@index([templateId])
  @@index([metricId])
  @@map("kra_template_item")
}

model EmployeeTarget {
  id                Int               @id @default(autoincrement())
  employeeProfileId Int
  period            PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  periodId          Int
  templateId        Int?
  targetJson        String            @default("") @db.Text
  status            String            @default("active")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  achievements KRAAchievement[]
  reviews      PerformanceReview[]

  @@index([employeeProfileId])
  @@index([periodId])
  @@index([templateId])
  @@index([status])
  @@map("employee_target")
}

model TeamTarget {
  id         Int               @id @default(autoincrement())
  teamId     Int
  period     PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  periodId   Int
  targetJson String            @default("") @db.Text
  status     String            @default("active")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([teamId])
  @@index([periodId])
  @@map("team_target")
}

model KRAAchievement {
  id               Int            @id @default(autoincrement())
  employeeTarget   EmployeeTarget @relation(fields: [employeeTargetId], references: [id], onDelete: Cascade)
  employeeTargetId Int
  metric           KRAMetric      @relation(fields: [metricId], references: [id], onDelete: Restrict)
  metricId         Int
  actualValue      Float          @default(0)
  achievementPct   Float          @default(0)
  weightedScore    Float          @default(0)
  sourceReference  String         @default("")
  calculatedAt     DateTime       @default(now())
  status           String         @default("active")

  @@index([employeeTargetId])
  @@index([metricId])
  @@map("kra_achievement")
}

model PerformanceReview {
  id               Int            @id @default(autoincrement())
  employeeTarget   EmployeeTarget @relation(fields: [employeeTargetId], references: [id], onDelete: Cascade)
  employeeTargetId Int
  reviewerId       Int
  workflowRequestId Int?
  selfRating       Float          @default(0)
  managerRating    Float          @default(0)
  finalRating      Float          @default(0)
  comments         String         @default("") @db.Text
  status           String         @default("DRAFT")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([employeeTargetId])
  @@index([reviewerId])
  @@index([status])
  @@map("performance_review")
}

model PerformanceAudit {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  action      String
  oldValue    String   @default("") @db.Text
  newValue    String   @default("") @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("performance_audit")
}

