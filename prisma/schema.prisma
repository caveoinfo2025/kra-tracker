generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Employee {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  department String
  role       String
  isManager  Boolean  @default(false)
  msEmail    String?  @unique
  msId       String?  @unique
  createdAt  DateTime @default(now())

  reportsToId Int?
  reportsTo   Employee?  @relation("OrgChart", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports     Employee[] @relation("OrgChart")

  kras           KRA[]
  reviews        WeeklyReview[]
  leads          LeadGeneration[]
  funnel         SalesFunnel[]
  collections    Collection[]
  dailyUpdates   DailyUpdate[]
  weeklyCommits  WeeklyCommit[]
  certifications Certification[]

  paymentsRecorded Payment[]      @relation("PaymentRecordedBy")
  advancesRecorded OrderAdvance[] @relation("AdvanceRecordedBy")
  notifications    Notification[] @relation("NotificationRecipient")

  assignedLeads      CrmLead[]     @relation("LeadAssignedTo")
  createdLeads       CrmLead[]     @relation("LeadCreatedBy")
  pipelineTasks      CrmTask[]     @relation("TaskAssignedTo")
  pipelineMeetings   CrmMeeting[]  @relation("MeetingEmployee")
  pipelineActivities CrmActivity[] @relation("ActivityPerformedBy")
  pipelineNotes      CrmNote[]     @relation("NoteAuthor")

  // Гў"в‚¬Гў"в‚¬ Finance Operations Module (Phase 1) Гў"в‚¬Гў"в‚¬
  ledgerEntries            Ledger[]          @relation("LedgerRecordedBy")
  expenses                 Expense[]         @relation("ExpenseEmployee")
  expensesApproved         Expense[]         @relation("ExpenseApprovedBy")
  vouchersCreated          Voucher[]         @relation("VoucherCreatedBy")
  employeeAdvances         EmployeeAdvance[] @relation("AdvanceEmployee")
  employeeAdvancesApproved EmployeeAdvance[] @relation("AdvanceApprovedBy")
  travelClaims             TravelClaim[]     @relation("TravelClaimEmployee")
  travelClaimsApproved     TravelClaim[]     @relation("TravelClaimApprovedBy")
  auditLogs                AuditLog[]        @relation("AuditPerformedBy")

  // Гў"в‚¬Гў"в‚¬ Admin Console Phase 2 (back-references Гўв‚¬" no DB columns on Employee) Гў"в‚¬Гў"в‚¬
  employeeProfile  EmployeeProfile?  @relation("ProfileEmployee")
  reporteeProfiles EmployeeProfile[] @relation("ProfileReportingManager")
  teamLeadOf       Team[]            @relation("TeamLead")
  userRoles        UserRole[]

  // Гў"в‚¬Гў"в‚¬ Phase 5 Гўв‚¬" Policy Engine (back-references Гўв‚¬" no DB columns on Employee) Гў"в‚¬Гў"в‚¬
  policiesCreated      Policy[]               @relation("PolicyCreatedBy")
  policiesApproved     Policy[]               @relation("PolicyApprovedBy")
  policyVersions       PolicyVersion[]        @relation("PolicyVersionCreatedBy")
  policyAudits         PolicyAudit[]          @relation("PolicyAuditPerformedBy")
  configVersionsChanged  ConfigurationVersion[] @relation("ConfigVersionChangedBy")
  configVersionsReviewed ConfigurationVersion[] @relation("ConfigVersionReviewedBy")

  // Гў"в‚¬Гў"в‚¬ Phase 6 Гўв‚¬" Workflow Engine (back-references Гўв‚¬" no DB columns on Employee) Гў"в‚¬Гў"в‚¬
  workflowsCreated     WorkflowDefinition[] @relation("WorkflowCreatedBy")
  approvalRequests     ApprovalRequest[]    @relation("WorkflowRequestedBy")
  approvalActions      ApprovalAction[]     @relation("ApprovalActionBy")
  delegationsFrom      DelegationRule[]     @relation("DelegationFrom")
  delegationsTo        DelegationRule[]     @relation("DelegationTo")
  escalationTargets    EscalationRule[]     @relation("EscalationTarget")
  workflowAuditLogs    WorkflowAuditLog[]   @relation("WorkflowAuditActor")

  // Гў"в‚¬Гў"в‚¬ Phase 7 Гўв‚¬" Master Data Management (back-references Гўв‚¬" no DB columns on Employee) Гў"в‚¬Гў"в‚¬
  masterAudits  MasterAudit[] @relation("MasterAuditPerformedBy")

  @@index([reportsToId])
}

model KRA {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  target      String   @db.Text
  deadline    DateTime
  weight      Int      @default(100)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  Int

  reviews        WeeklyReview[]
  weeklyCommits  WeeklyCommit[]
  certifications Certification[]

  @@index([employeeId])
}

model WeeklyReview {
  id         Int      @id @default(autoincrement())
  week       Int
  year       Int
  progress   Int
  score      Int
  notes      String   @db.Text
  blockers   String   @default("") @db.Text
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId      Int

  @@index([employeeId])
  @@index([kraId])
}

model LeadGeneration {
  id             Int       @id @default(autoincrement())
  date           DateTime  @default(now())
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     Int
  territory      String    @default("")
  leadSource     String    @default("")
  customerName   String
  contactPerson  String    @default("")
  phoneEmail     String    @default("")
  activityType   String    @default("")
  activityCount  Int       @default(1)
  leadStatus     String    @default("New")
  qualifiedFlag  Boolean   @default(false)
  nextActionDate DateTime?
  remarks        String    @default("") @db.Text
  createdAt      DateTime  @default(now())

  @@index([employeeId])
}

model SalesFunnel {
  id                Int       @id @default(autoincrement())
  opportunityId     String    @default("")
  createdDate       DateTime  @default(now())
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId        Int
  territory         String    @default("")
  customerName      String
  solutionCategory  String    @default("")
  opportunityName   String
  stage             String    @default("Lead")
  dealValueLakhs    Float     @default(0)
  billingValueLakhs Float     @default(0)
  grossProfitPct    Float     @default(0)
  proposalDate      DateTime?
  expectedCloseDate DateTime?
  poDate            DateTime?
  closedDate        DateTime?
  probabilityPct    Float     @default(0)
  status            String    @default("Active")
  newCustomerFlag   Boolean   @default(false)
  pocFlag           Boolean   @default(false)
  remarks           String    @default("") @db.Text
  createdAt         DateTime  @default(now())
  crmOpportunityId  Int?      // set when this legacy deal is promoted to a real CrmOpportunity

  @@index([employeeId])
  @@index([stage, status])
}

model Collection {
  id                    Int       @id @default(autoincrement())
  invoiceDate           DateTime  @default(now())
  invoiceNo             String    @default("")
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId            Int
  customerName          String
  invoiceValueLakhs     Float
  amountWithoutGstLakhs Float     @default(0)
  dueDate               DateTime
  paymentReceivedDate   DateTime?
  amountReceivedLakhs   Float     @default(0)
  collectionStatus      String    @default("Pending")
  remarks               String    @default("") @db.Text
  createdAt             DateTime  @default(now())

  payments Payment[]

  @@index([employeeId])
  @@index([collectionStatus])
  @@index([dueDate])
}

model Payment {
  id            Int        @id @default(autoincrement())
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  Int
  amountLakhs   Float
  paymentDate   DateTime   @default(now())
  mode          String     @default("Bank Transfer")
  referenceNo   String     @default("")
  notes         String     @default("") @db.Text
  fromAdvanceId Int?
  recordedBy    Employee   @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  recordedById  Int
  createdAt     DateTime   @default(now())

  @@index([collectionId])
  @@index([paymentDate])
  @@index([recordedById])
}

model OrderAdvance {
  id                    Int       @id @default(autoincrement())
  salesFunnelId         Int?
  customerName          String
  amountLakhs           Float
  receivedDate          DateTime  @default(now())
  mode                  String    @default("Bank Transfer")
  referenceNo           String    @default("")
  notes                 String    @default("") @db.Text
  status                String    @default("unapplied")
  appliedToCollectionId Int?
  appliedDate           DateTime?
  recordedBy            Employee  @relation("AdvanceRecordedBy", fields: [recordedById], references: [id])
  recordedById          Int

  createdAt DateTime @default(now())

  @@index([recordedById])
  @@index([status])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipient   Employee @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId Int
  type        String
  title       String
  body        String   @default("") @db.Text
  link        String   @default("")
  amountLakhs Float?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([createdAt])
}

model DailyUpdate {
  id                     Int      @id @default(autoincrement())
  date                   DateTime @default(now())
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId             Int
  topUpdates             String   @db.Text
  keyMovement            String   @default("") @db.Text
  blockers               String   @default("") @db.Text
  topDealThisWeek        String   @default("") @db.Text
  managerSupportRequired Boolean  @default(false)
  updateStatus           String   @default("On Track")
  createdAt              DateTime @default(now())

  @@index([employeeId, date])
}

model WeeklyCommit {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId      Int
  week       Int
  year       Int
  commitText String   @default("") @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, week, year])
  @@index([kraId])
}

model Certification {
  id            Int       @id @default(autoincrement())
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId    Int
  kra           KRA       @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId         Int
  certName      String
  issuingBody   String    @default("")
  dateObtained  DateTime
  expiryDate    DateTime?
  attachmentUrl String    @default("")
  status        String    @default("pending")
  approvedBy    Int?
  approvedAt    DateTime?
  remarks       String    @default("") @db.Text
  createdAt     DateTime  @default(now())

  @@index([employeeId])
  @@index([kraId])
}

model CrmLead {
  id            Int      @id @default(autoincrement())
  title         String
  companyName   String
  contactPerson String
  email         String   @default("")
  phone         String   @default("")
  source        String   @default("Direct")
  categoryId    String?
  categoryName  String   @default("")
  oemId         String?
  oemName       String   @default("")
  productId     String?
  productName   String   @default("")
  customerId    String?
  customerName  String   @default("")
  stage         String   @default("NEW_LEAD")
  expectedValue Float    @default(0)
  remarks       String   @default("") @db.Text
  assignedTo    Employee @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  assignedToId  Int
  createdBy     Employee @relation("LeadCreatedBy", fields: [createdById], references: [id])
  createdById   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity CrmOpportunity?
  tasks       CrmTask[]
  meetings    CrmMeeting[]
  activities  CrmActivity[]
  notes       CrmNote[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([stage])
}

model CrmOpportunity {
  id                  Int       @id @default(autoincrement())
  lead                CrmLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId              Int       @unique
  stage               String    @default("PROPOSAL_SENT")
  value               Float     @default(0)
  expectedClosureDate DateTime?
  probability         Int       @default(50)
  discountPct         Float     @default(0)   // discount % requested (0-100); triggers approval when > 0
  lostReason          String    @default("") @db.Text
  // Closed Won fields вЂ” required when stage в†’ WON
  dealValueExTax      Float     @default(0)   // deal value excluding tax (в‚№L)
  netProfitLakhs      Float     @default(0)   // net profit (absolute, в‚№L)
  poNumber            String    @default("")  // purchase order number
  poDate              DateTime?               // PO date
  status              String    @default("active")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tasks      CrmTask[]
  meetings   CrmMeeting[]
  activities CrmActivity[]

  @@index([stage, status])
}

model CrmTask {
  id            Int             @id @default(autoincrement())
  title         String
  description   String          @default("") @db.Text
  dueDate       DateTime
  assignedTo    Employee        @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  assignedToId  Int
  status        String          @default("pending")
  priority      String          @default("medium")
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([assignedToId])
  @@index([leadId])
  @@index([opportunityId])
}

model CrmMeeting {
  id            Int             @id @default(autoincrement())
  title         String
  meetingDate   DateTime
  notes         String          @default("") @db.Text
  attendees     String          @default("") @db.Text
  location      String          @default("")
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?
  employee      Employee        @relation("MeetingEmployee", fields: [employeeId], references: [id])
  employeeId    Int
  createdAt     DateTime        @default(now())

  @@index([leadId])
  @@index([opportunityId])
  @@index([employeeId])
}

model CrmActivity {
  id            Int             @id @default(autoincrement())
  entityType    String
  entityId      Int
  action        String
  description   String          @default("") @db.Text
  meta          String          @default("") @db.Text
  performedBy   Employee        @relation("ActivityPerformedBy", fields: [performedById], references: [id])
  performedById Int
  timestamp     DateTime        @default(now())
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?

  @@index([leadId])
  @@index([opportunityId])
  @@index([performedById])
  @@index([timestamp])
}

model CrmNote {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    Int
  author    Employee @relation("NoteAuthor", fields: [authorId], references: [id])
  authorId  Int
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([authorId])
}

model Customer {
  id         Int        @id @default(autoincrement())
  name       String
  address    String     @default("") @db.Text
  district   String     @default("")
  state      String     @default("")
  pincode    String     @default("")
  gstNo      String     @default("")
  officeType String     @default("HO")
  parentId   Int?
  parent     Customer?  @relation("CustomerBranches", fields: [parentId], references: [id])
  branches   Customer[] @relation("CustomerBranches")
  crmSource  String     @default("")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([parentId])
  @@index([name])
}

model AppSetting {
  id          Int      @id @default(autoincrement())
  category    String
  key         String   @unique
  label       String
  value       String   @db.Text
  description String   @default("") @db.Text
  updatedAt   DateTime @updatedAt
  updatedById Int?
}

model AppRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  label       String
  level       Int
  color       String   @default("#6b7280")
  isSystem    Boolean  @default(false)
  description String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pageAccess RolePageAccess[]
}

model RolePageAccess {
  id        Int     @id @default(autoincrement())
  role      AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    Int
  pageKey   String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([roleId, pageKey])
}

// ============================================================
// Finance Operations Module Гўв‚¬" Phase 1 (database only)
// Provider: mysql Г‚В· money in ГўвЂљВ№ Lakhs (Float -> DOUBLE) Г‚В· long text uses @db.Text
// Every FK + hot-filter column is indexed. No API/UI in this phase.
// Module ГўвЂ вЂ™ model map:
//   Account        -> FinAccount       (chart of accounts: cash + bank)
//   Ledger         -> Ledger           (general ledger entries)
//   Expense        -> Expense          (expense register; category + attachments inline)
//   Vendor         -> Vendor
//   Voucher        -> Voucher (+ VoucherSequence for atomic per-FY numbering)
//   EmployeeAdvance-> EmployeeAdvance
//   TravelClaim    -> TravelClaim      (local conveyance / travel reimbursement)
//   ApprovalRule   -> ApprovalRule     (configurable amount-limit approval policy)
//   AuditLog       -> AuditLog         (generic financial audit trail)
// ============================================================

// Гў"в‚¬Гў"в‚¬ Account: chart of accounts (cash & bank) Гў"в‚¬Гў"в‚¬
model FinAccount {
  id             Int      @id @default(autoincrement())
  name           String
  type           String   @default("cash") // "cash" | "bank"
  branchName     String   @default("HO")
  bankName       String   @default("")
  accountNo      String   @default("")
  ifscCode       String   @default("")
  accountHolder  String   @default("")
  openingBalance Float    @default(0)
  currentBalance Float    @default(0) // CACHED Гўв‚¬" written by the cash/bank service only
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ledgerEntries Ledger[]

  @@index([type])
  @@index([isActive])
}

// Гў"в‚¬Гў"в‚¬ Ledger: general ledger entries posted against an account Гў"в‚¬Гў"в‚¬
model Ledger {
  id             Int        @id @default(autoincrement())
  account        FinAccount @relation(fields: [accountId], references: [id])
  accountId      Int
  entryDate      DateTime   @default(now())
  type           String // upi|cheque|neft|rtgs|imps|cash_in|cash_out|receipt|payment|bank_charge|transfer
  direction      String // "debit" | "credit"
  amountLakhs    Float
  narration      String     @default("") @db.Text
  referenceNo    String     @default("")
  chequeNo       String     @default("")
  chequeDate     DateTime?
  payee          String     @default("")
  voucher        Voucher?   @relation(fields: [voucherId], references: [id])
  voucherId      Int?
  pairedLedgerId Int? // soft self-pair for bank<->cash transfers
  reconciled     Boolean    @default(false)
  reconciledAt   DateTime?
  recordedBy     Employee   @relation("LedgerRecordedBy", fields: [recordedById], references: [id])
  recordedById   Int
  createdAt      DateTime   @default(now())

  @@index([accountId])
  @@index([entryDate])
  @@index([type])
  @@index([reconciled])
  @@index([voucherId])
  @@index([recordedById])
}

// Гў"в‚¬Гў"в‚¬ Vendor master Гў"в‚¬Гў"в‚¬
model Vendor {
  id            Int      @id @default(autoincrement())
  name          String
  gstin         String   @default("")
  pan           String   @default("")
  address       String   @default("") @db.Text
  city          String   @default("")
  state         String   @default("")
  pincode       String   @default("")
  contactName   String   @default("")
  contactPhone  String   @default("")
  contactEmail  String   @default("")
  bankName      String   @default("")
  bankAccountNo String   @default("")
  ifscCode      String   @default("")
  paymentTerms  String   @default("30 days")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  expenses Expense[]

  @@index([name])
  @@index([isActive])
}

// Гў"в‚¬Гў"в‚¬ Expense register (category + attachments held inline for Phase 1) Гў"в‚¬Гў"в‚¬
model Expense {
  id              Int       @id @default(autoincrement())
  category        String    @default("") // category name
  categoryCode    String    @default("") // short code, e.g. TRVL
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])
  vendorId        Int?
  customerName    String    @default("") // denormalized customer tag (profitability)
  employee        Employee  @relation("ExpenseEmployee", fields: [employeeId], references: [id])
  employeeId      Int
  expenseDate     DateTime  @default(now())
  amountLakhs     Float
  gstRate         Float     @default(0)
  gstAmountLakhs  Float     @default(0)
  narration       String    @default("") @db.Text
  vendorInvoiceNo String    @default("")
  attachmentsJson String    @default("[]") @db.Text // JSON array of { fileName, fileUrl }
  status          String    @default("draft") // draft|submitted|approved|rejected|paid
  voucher         Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId       Int?
  approvedBy      Employee? @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  approvedById    Int?
  approvedAt      DateTime?
  paidDate        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([category])
  @@index([vendorId])
  @@index([employeeId])
  @@index([expenseDate])
  @@index([status])
  @@index([customerName])
  @@index([voucherId])
}

// Гў"в‚¬Гў"в‚¬ Voucher Гў"в‚¬Гў"в‚¬
model Voucher {
  id          Int       @id @default(autoincrement())
  voucherNo   String    @unique // CI/26-27/00001
  type        String // payment|receipt|journal|expense|conveyance|advance
  voucherDate DateTime  @default(now())
  amountLakhs Float
  narration   String    @default("") @db.Text
  status      String    @default("draft") // draft|approved|voided
  pdfUrl      String    @default("") @db.Text
  voidedAt    DateTime?
  voidReason  String    @default("") @db.Text
  createdBy   Employee  @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  createdById Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ledgerEntries Ledger[]
  expenses      Expense[]
  travelClaims  TravelClaim[]
  advances      EmployeeAdvance[]

  @@index([voucherDate])
  @@index([type])
  @@index([status])
  @@index([createdById])
}

// Гў"в‚¬Гў"в‚¬ Voucher sequence: atomic per-financial-year numbering (supports Voucher) Гў"в‚¬Гў"в‚¬
model VoucherSequence {
  id            Int      @id @default(autoincrement())
  financialYear String   @unique // "26-27"
  lastNumber    Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// Гў"в‚¬Гў"в‚¬ Employee advance Гў"в‚¬Гў"в‚¬
model EmployeeAdvance {
  id                   Int       @id @default(autoincrement())
  advanceNo            String    @unique // CI/ADV/26-27/00001
  employee             Employee  @relation("AdvanceEmployee", fields: [employeeId], references: [id])
  employeeId           Int
  purpose              String    @default("") @db.Text
  amountLakhs          Float
  requestDate          DateTime  @default(now())
  requiredByDate       DateTime?
  status               String    @default("pending") // pending|approved|disbursed|settled|rejected
  approvedBy           Employee? @relation("AdvanceApprovedBy", fields: [approvedById], references: [id])
  approvedById         Int?
  approvedAt           DateTime?
  disbursedDate        DateTime?
  disbursedAmountLakhs Float?
  disbursedFromType    String    @default("") // "cash" | "bank"
  disbursedFromId      Int? // soft ref to FinAccount.id
  settledDate          DateTime?
  settledAmountLakhs   Float?
  balanceLakhs         Float     @default(0) // CACHED: disbursed ГўЛ†вЂ™ settled
  voucher              Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId            Int?
  remarks              String    @default("") @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([employeeId])
  @@index([status])
  @@index([requestDate])
  @@index([voucherId])
}

// Гў"в‚¬Гў"в‚¬ Travel claim: local conveyance / travel reimbursement (GPS-aware) Гў"в‚¬Гў"в‚¬
model TravelClaim {
  id           Int       @id @default(autoincrement())
  claimNo      String    @unique // CI/TRV/26-27/00001
  employee     Employee  @relation("TravelClaimEmployee", fields: [employeeId], references: [id])
  employeeId   Int
  travelDate   DateTime  @default(now())
  fromLocation String    @default("") @db.Text
  toLocation   String    @default("") @db.Text
  fromLat      Float?
  fromLng      Float?
  toLat        Float?
  toLng        Float?
  distanceKm   Float     @default(0)
  mode         String    @default("bike") // bike|car|auto|public
  ratePerKm    Float     @default(0) // ГўвЂљВ№ per km (snapshot from HR policy)
  amountRupees Float     @default(0)
  amountLakhs  Float     @default(0)
  purpose      String    @default("") @db.Text
  status       String    @default("draft") // draft|submitted|approved|rejected|paid
  approvedBy   Employee? @relation("TravelClaimApprovedBy", fields: [approvedById], references: [id])
  approvedById Int?
  approvedAt   DateTime?
  voucher      Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([employeeId])
  @@index([travelDate])
  @@index([status])
  @@index([voucherId])
}

// Гў"в‚¬Гў"в‚¬ Approval rule: configurable amount-limit approval policy Гў"в‚¬Гў"в‚¬
model ApprovalRule {
  id               Int      @id @default(autoincrement())
  name             String
  entityType       String   @default("all") // all|expense|advance|travel|voucher
  autoApproveLimit Float    @default(0)
  level1Limit      Float    @default(0)
  level1Role       String   @default("")
  level2Limit      Float?
  level2Role       String?
  level3Limit      Float?
  level3Role       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([entityType])
  @@index([isActive])
}

// Гў"в‚¬Гў"в‚¬ Audit log: generic financial audit trail Гў"в‚¬Гў"в‚¬
model AuditLog {
  id            Int      @id @default(autoincrement())
  entityType    String // expense|voucher|ledger|account|advance|travel_claim|vendor|approval
  entityId      Int
  action        String // create|update|submit|approve|reject|void|disburse|settle|delete|reconcile
  performedBy   Employee @relation("AuditPerformedBy", fields: [performedById], references: [id])
  performedById Int
  changes       String   @default("") @db.Text // JSON before/after or detail
  notes         String   @default("") @db.Text
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([action])
  @@index([createdAt])
}

// Finance Administration Engine - Phase 9
// 8 models: FinancePolicy, ExpenseCategory, ExpenseLimitRule, ConveyancePolicy,
// AdvancePolicy, CustomerCreditPolicy, VoucherConfiguration, CollectionPolicy

model FinancePolicy {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  policyName  String
  policyType  String
  policyCode  String   @default("")
  description String   @default("") @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([policyType])
  @@index([status])
  @@map("finance_policy")
}

model ExpenseCategory {
  id               Int      @id @default(autoincrement())
  companyId        Int?
  name             String
  code             String   @unique
  description      String   @default("") @db.Text
  requiresReceipt  Boolean  @default(false)
  requiresApproval Boolean  @default(false)
  parentId         Int?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent     ExpenseCategory?   @relation("CatParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   ExpenseCategory[]  @relation("CatParent")
  limitRules ExpenseLimitRule[]

  @@index([companyId])
  @@index([parentId])
  @@index([status])
  @@map("expense_category")
}

model ExpenseLimitRule {
  id                Int             @id @default(autoincrement())
  expenseCategory   ExpenseCategory @relation(fields: [expenseCategoryId], references: [id], onDelete: Cascade)
  expenseCategoryId Int
  scopeType         String
  scopeId           String
  dailyLimit        Float           @default(0)
  monthlyLimit      Float           @default(0)
  yearlyLimit       Float           @default(0)
  policyCode        String          @default("")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([expenseCategoryId])
  @@index([scopeType, scopeId])
  @@map("expense_limit_rule")
}

model ConveyancePolicy {
  id                       Int      @id @default(autoincrement())
  companyId                Int?
  vehicleType              String
  ratePerKm                Float    @default(0)
  monthlyLimitRupees       Float    @default(0)
  googleMapRequired        Boolean  @default(false)
  allowManualOverride      Boolean  @default(true)
  overrideApprovalRequired Boolean  @default(false)
  status                   String   @default("active")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([companyId])
  @@index([vehicleType])
  @@index([status])
  @@map("conveyance_policy")
}

model AdvancePolicy {
  id               Int      @id @default(autoincrement())
  companyId        Int?
  maxAdvanceLakhs  Float    @default(0)
  settlementDays   Int      @default(30)
  approvalRequired Boolean  @default(true)
  policyCode       String   @default("")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@map("advance_policy")
}

model CustomerCreditPolicy {
  id                      Int      @id @default(autoincrement())
  companyId               Int?
  customerType            String   @default("STANDARD")
  defaultCreditLimitLakhs Float    @default(0)
  maxCreditLimitLakhs     Float    @default(0)
  approvalAboveLimit      Boolean  @default(true)
  paymentTermsDays        Int      @default(30)
  status                  String   @default("active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
  @@index([customerType])
  @@map("customer_credit_policy")
}

model VoucherConfiguration {
  id                 Int      @id @default(autoincrement())
  companyId          Int?
  voucherType        String
  prefix             String   @default("")
  numberFormat       String   @default("PREFIX-YEAR-SEQ")
  runningNumber      Int      @default(0)
  financialYearReset Boolean  @default(true)
  financialYear      String   @default("")
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
  @@index([voucherType])
  @@map("voucher_configuration")
}

model CollectionPolicy {
  id             Int      @id @default(autoincrement())
  companyId      Int?
  reminderDays   Int      @default(7)
  escalationDays Int      @default(14)
  creditHoldDays Int      @default(30)
  policyCode     String   @default("")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@map("collection_policy")
}

// ============================================================
// Admin Console вЂ” Phase 2 Foundation
// Org Structure Г‚В· Employee Profile Extension Г‚В· Enterprise RBAC
// Provider: mysql Г‚В· All String long-text ГўвЂ вЂ™ @db.Text
// Every FK + filter column is indexed. No workflow/finance yet.
// ============================================================

// Гў"в‚¬Гў"в‚¬ 1. Tenant Гўв‚¬" top-level organisation group Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Tenant {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  companies Company[]
  roles     Role[]

  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 2. Company Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Company {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  companyName String
  legalName   String   @default("")
  companyCode String   @default("")
  gstNumber   String   @default("")
  panNumber   String   @default("")
  email       String   @default("")
  phone       String   @default("")
  website     String   @default("")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branches         Branch[]
  departments      Department[]
  designations     Designation[]
  employeeProfiles EmployeeProfile[]

  @@index([tenantId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 3. Branch Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Branch {
  id         Int      @id @default(autoincrement())
  companyId  Int
  branchName String
  branchCode String   @default("")
  address    String   @default("") @db.Text
  city       String   @default("")
  state      String   @default("")
  country    String   @default("India")
  timezone   String   @default("Asia/Kolkata")
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 4. Department Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Department {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String
  code        String   @default("")
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  teams            Team[]
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 5. Team Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Team {
  id           Int      @id @default(autoincrement())
  departmentId Int
  name         String
  teamLeadId   Int?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department       Department        @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  teamLead         Employee?         @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  employeeProfiles EmployeeProfile[]

  @@index([departmentId])
  @@index([teamLeadId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 6. Designation Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model Designation {
  id          Int      @id @default(autoincrement())
  companyId   Int
  title       String
  level       Int      @default(1)
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 7. EmployeeProfile Гўв‚¬" enterprise HR record (extends Employee) Гў"в‚¬Гў"в‚¬
// employmentStatus: DRAFT | ACTIVE | SUSPENDED | INACTIVE
model EmployeeProfile {
  id                 Int       @id @default(autoincrement())
  userId             Int       @unique // FK ГўвЂ вЂ™ Employee.id (Employee IS the auth user)
  employeeCode       String    @default("")
  companyId          Int?
  branchId           Int?
  departmentId       Int?
  teamId             Int?
  designationId      Int?
  reportingManagerId Int?
  joiningDate        DateTime?
  employmentStatus   String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employee          Employee     @relation("ProfileEmployee", fields: [userId], references: [id], onDelete: Cascade)
  company           Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch            Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department        Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team              Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  designation       Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingManager  Employee?    @relation("ProfileReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([teamId])
  @@index([designationId])
  @@index([reportingManagerId])
  @@index([employmentStatus])
}

// Гў"в‚¬Гў"в‚¬ 8. Role Гўв‚¬" enterprise role (additive; AppRole legacy kept) Гў"в‚¬Гў"в‚¬
// isSystemRole: true means not deletable via UI
model Role {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  name         String
  description  String   @default("") @db.Text
  level        Int      @default(1)
  isSystemRole Boolean  @default(false)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  rolePermissions   RolePermission[]
  userRoles         UserRole[]
  dataAccessPolicies DataAccessPolicy[]

  @@index([tenantId])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 9. Permission Гўв‚¬" granular action catalogue Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
// Unique per (module, resource, action) Гўв‚¬" same across all tenants.
model Permission {
  id          Int    @id @default(autoincrement())
  module      String // CRM | Finance | Workflow | Settings | Reports | Masters
  resource    String // Lead | Opportunity | Expense | Invoice | ...
  action      String // VIEW | CREATE | EDIT | DELETE | APPROVE | EXPORT | IMPORT | ASSIGN
  description String @default("") @db.Text

  rolePermissions RolePermission[]

  @@unique([module, resource, action])
  @@index([module])
}

// Гў"в‚¬Гў"в‚¬ 10. RolePermission Гўв‚¬" grants permission to a role Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// Гў"в‚¬Гў"в‚¬ 11. UserRole Гўв‚¬" multiple roles per employee Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      // FK ГўвЂ вЂ™ Employee.id
  roleId    Int
  createdAt DateTime @default(now())

  employee  Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// Гў"в‚¬Гў"в‚¬ 12. DataAccessPolicy Гўв‚¬" per-role data visibility scope Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
// scope: OWN | TEAM | DEPARTMENT | BRANCH | COMPANY | ALL
// filterJson: optional JSON string for additional WHERE constraints
model DataAccessPolicy {
  id         Int      @id @default(autoincrement())
  roleId     Int
  module     String   @default("")
  scope      String   @default("OWN")
  filterJson String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@index([roleId])
  @@index([scope])
}

// ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ
// Phase 5 Гўв‚¬" Policy Engine
// ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ

// Гў"в‚¬Гў"в‚¬ 13. PolicyCategory Гўв‚¬" groups policies by domain Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model PolicyCategory {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policies Policy[]

  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 14. Policy Гўв‚¬" a versioned, lifecycle-managed business rule Гў"в‚¬
// scopeType: GLOBAL | COMPANY | BRANCH | DEPARTMENT | ROLE | USER
// status:    DRAFT | REVIEW | ACTIVE | INACTIVE | ARCHIVED
model Policy {
  id            Int       @id @default(autoincrement())
  categoryId    Int
  name          String
  code          String    @unique
  description   String    @default("") @db.Text
  scopeType     String    @default("GLOBAL")
  scopeId       Int?
  status        String    @default("DRAFT")
  version       Int       @default(1)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdBy     Int
  approvedBy    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category PolicyCategory @relation(fields: [categoryId], references: [id])
  creator  Employee       @relation("PolicyCreatedBy",  fields: [createdBy],  references: [id])
  approver Employee?      @relation("PolicyApprovedBy", fields: [approvedBy], references: [id])

  rules    PolicyRule[]
  versions PolicyVersion[]
  audits   PolicyAudit[]

  @@index([categoryId])
  @@index([status])
  @@index([scopeType, scopeId])
}

// Гў"в‚¬Гў"в‚¬ 15. PolicyRule Гўв‚¬" individual IF/THEN rule inside a policy Гў"в‚¬Гў"в‚¬
model PolicyRule {
  id            Int      @id @default(autoincrement())
  policyId      Int
  ruleName      String
  priority      Int      @default(10)
  conditionJson String   @db.Text  // JSON: { field, operator, value } or { and/or: [...] }
  actionJson    String   @db.Text  // JSON: { type, ...params }
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([priority])
}

// Гў"в‚¬Гў"в‚¬ 16. PolicyVersion Гўв‚¬" immutable snapshot per publish cycle Гў"в‚¬Гў"в‚¬
model PolicyVersion {
  id            Int      @id @default(autoincrement())
  policyId      Int
  versionNumber Int
  snapshotJson  String   @db.Text  // full Policy + rules JSON at publish time
  changeReason  String   @default("") @db.Text
  createdBy     Int
  createdAt     DateTime @default(now())

  policy  Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  creator Employee @relation("PolicyVersionCreatedBy", fields: [createdBy], references: [id])

  @@unique([policyId, versionNumber])
  @@index([policyId])
}

// Гў"в‚¬Гў"в‚¬ 17. PolicyAudit Гўв‚¬" every change to a policy Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬Гў"в‚¬
model PolicyAudit {
  id          Int      @id @default(autoincrement())
  policyId    Int
  action      String   // CREATED | UPDATED | STATUS_CHANGED | RULE_ADDED | RULE_REMOVED | PUBLISHED | ARCHIVED
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  policy    Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  performer Employee @relation("PolicyAuditPerformedBy", fields: [performedBy], references: [id])

  @@index([policyId])
  @@index([performedBy])
}

// Гў"в‚¬Гў"в‚¬ 18. ConfigurationVersion Гўв‚¬" DraftГўвЂ вЂ™ReviewГўвЂ вЂ™Published settings Гў"в‚¬
// Enables lifecycle management for AppSetting values.
// getSetting() reads the latest published version; falls back to AppSetting row.
model ConfigurationVersion {
  id           Int       @id @default(autoincrement())
  settingKey   String
  value        String    @db.Text  // JSON-encoded setting value
  version      Int
  module       String
  status       String    @default("draft")  // draft | in_review | published | rolled_back
  changedById  Int
  reviewedById Int?
  publishedAt  DateTime?
  note         String?   @db.Text
  createdAt    DateTime  @default(now())

  changedBy  Employee  @relation("ConfigVersionChangedBy",  fields: [changedById],  references: [id])
  reviewedBy Employee? @relation("ConfigVersionReviewedBy", fields: [reviewedById], references: [id])

  @@unique([settingKey, version])
  @@index([settingKey, status])
  @@index([changedById])
}

// ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ
// Phase 6 Гўв‚¬" Workflow Engine
// ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ

// Гў"в‚¬Гў"в‚¬ 19. WorkflowDefinition Гўв‚¬" a named, versioned approval workflow Гў"в‚¬Гў"в‚¬
// status:  DRAFT | ACTIVE | INACTIVE
// module:  CRM | FINANCE | HR | SECURITY | MASTERS | WORKFLOW | PROCUREMENT | PROJECTS
model WorkflowDefinition {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  description   String   @default("") @db.Text
  module        String
  triggerEvent  String
  status        String   @default("DRAFT")
  conditionJson String?  @db.Text  // optional JSON condition for auto-trigger matching
  version       Int      @default(1)
  createdBy     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator         Employee         @relation("WorkflowCreatedBy", fields: [createdBy], references: [id])
  steps           WorkflowStep[]
  requests        ApprovalRequest[]
  escalationRules EscalationRule[]

  @@map("workflow_definition")
  @@index([module, triggerEvent])
  @@index([status])
  @@index([createdBy])
}

// Гў"в‚¬Гў"в‚¬ 20. WorkflowStep Гўв‚¬" one level/step inside a workflow definition Гў"в‚¬Гў"в‚¬
// approvalType: USER | ROLE | REPORTING_MANAGER | DEPARTMENT_HEAD | POLICY_BASED
// approvalMode: SEQUENTIAL | PARALLEL
model WorkflowStep {
  id              Int      @id @default(autoincrement())
  workflowId      Int
  stepNumber      Int
  stepName        String
  approvalType    String   @default("REPORTING_MANAGER")
  approverId      Int?     // employee id (for USER type)
  approverRoleId  Int?     // role id (for ROLE type)
  approvalMode    String   @default("SEQUENTIAL")
  isMandatory     Boolean  @default(true)
  timeoutHours    Int      @default(24)
  requireComments Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow        WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions         ApprovalAction[]
  escalationRules EscalationRule[]

  @@map("workflow_step")
  @@index([workflowId])
  @@index([stepNumber])
}

// Гў"в‚¬Гў"в‚¬ 21. ApprovalRequest Гўв‚¬" a live approval in-flight for a business entity Гў"в‚¬Гў"в‚¬
// status: PENDING | APPROVED | REJECTED | RETURNED | CANCELLED
model ApprovalRequest {
  id          Int       @id @default(autoincrement())
  workflowId  Int
  entityType  String    // EXPENSE | DEAL | VENDOR | CUSTOMER | DISCOUNT | ADVANCE | etc.
  entityId    String    // string ID of the business entity
  requestedBy Int
  status      String    @default("PENDING")
  currentStep Int       @default(1)
  contextJson String?   @db.Text  // snapshot of entity data at submission
  submittedAt DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id])
  requester Employee           @relation("WorkflowRequestedBy", fields: [requestedBy], references: [id])
  actions   ApprovalAction[]

  @@map("approval_request")
  @@index([workflowId])
  @@index([requestedBy])
  @@index([status])
  @@index([entityType, entityId])
}

// Гў"в‚¬Гў"в‚¬ 22. ApprovalAction Гўв‚¬" a single action on a request (approve/reject/etc.) Гў"в‚¬Гў"в‚¬
// action: APPROVE | REJECT | RETURN | DELEGATE
model ApprovalAction {
  id         Int      @id @default(autoincrement())
  requestId  Int
  stepId     Int
  approverId Int
  action     String   // APPROVE | REJECT | RETURN | DELEGATE
  comments   String?  @db.Text
  toUserId   Int?     // target employee for DELEGATE action
  createdAt  DateTime @default(now())

  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step     WorkflowStep    @relation(fields: [stepId],    references: [id])
  approver Employee        @relation("ApprovalActionBy",  fields: [approverId], references: [id])

  @@map("approval_action")
  @@index([requestId])
  @@index([stepId])
  @@index([approverId])
}

// Гў"в‚¬Гў"в‚¬ 23. DelegationRule Гўв‚¬" user delegates approval rights for a date range Гў"в‚¬Гў"в‚¬
// status: ACTIVE | INACTIVE | EXPIRED
model DelegationRule {
  id        Int      @id @default(autoincrement())
  fromUser  Int
  toUser    Int
  module    String?  // null = all modules
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE")
  reason    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  from Employee @relation("DelegationFrom", fields: [fromUser], references: [id])
  to   Employee @relation("DelegationTo",   fields: [toUser],   references: [id])

  @@map("delegation_rule")
  @@index([fromUser])
  @@index([toUser])
  @@index([status])
}

// Гў"в‚¬Гў"в‚¬ 24. EscalationRule Гўв‚¬" time-based escalation config for a step Гў"в‚¬Гў"в‚¬
// action: REMIND | ESCALATE | AUTO_APPROVE | AUTO_REJECT
model EscalationRule {
  id          Int      @id @default(autoincrement())
  workflowId  Int
  stepId      Int?     // null = any step in this workflow
  afterHours  Int      @default(24)
  escalateTo  Int?     // FK Employee (for ESCALATE action)
  action      String   @default("REMIND")
  repeatEvery Int?     // hours between repeats (for REMIND)
  maxTriggers Int      @default(3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  step      WorkflowStep?      @relation(fields: [stepId],     references: [id])
  escalatee Employee?          @relation("EscalationTarget",   fields: [escalateTo], references: [id])

  @@map("escalation_rule")
  @@index([workflowId])
  @@index([stepId])
}

// Гў"в‚¬Гў"в‚¬ 25. WorkflowAuditLog Гўв‚¬" every lifecycle event in the workflow engine Гў"в‚¬Гў"в‚¬
// entityType: WORKFLOW_DEFINITION | APPROVAL_REQUEST
// action: CREATED | ASSIGNED | APPROVED | REJECTED | ESCALATED | DELEGATED | RETURNED | CANCELLED | COMPLETED
model WorkflowAuditLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  actorId    Int
  details    String?  @db.Text  // JSON context
  createdAt  DateTime @default(now())

  actor Employee @relation("WorkflowAuditActor", fields: [actorId], references: [id])

  @@map("workflow_audit_log")
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// ГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђГўвЂўВђ
// Phase 7 Гўв‚¬" Master Data Management
