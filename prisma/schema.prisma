generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Employee {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  department String
  role       String
  createdAt  DateTime @default(now())
  kras       KRA[]
  reviews    WeeklyReview[]
}

model KRA {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  target      String
  deadline    DateTime
  weight      Int      @default(100)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  Int
  reviews     WeeklyReview[]
}

model WeeklyReview {
  id         Int      @id @default(autoincrement())
  week       Int
  year       Int
  progress   Int
  score      Int
  notes      String
  blockers   String   @default("")
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId      Int
}
