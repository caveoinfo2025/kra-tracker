generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
}

model Employee {
  id         Int      @id @default(autoincrement())
  name       String
  email      String   @unique
  department String
  role       String
  isManager  Boolean  @default(false)
  msEmail    String?  @unique
  msId       String?  @unique
  createdAt  DateTime @default(now())

  reportsToId Int?
  reportsTo   Employee?  @relation("OrgChart", fields: [reportsToId], references: [id], onDelete: SetNull)
  reports     Employee[] @relation("OrgChart")

  kras           KRA[]
  reviews        WeeklyReview[]
  leads          LeadGeneration[]
  funnel         SalesFunnel[]
  collections    Collection[]
  dailyUpdates   DailyUpdate[]
  weeklyCommits  WeeklyCommit[]
  certifications Certification[]

  paymentsRecorded Payment[]      @relation("PaymentRecordedBy")
  advancesRecorded OrderAdvance[] @relation("AdvanceRecordedBy")
  notifications    Notification[] @relation("NotificationRecipient")

  assignedLeads      CrmLead[]     @relation("LeadAssignedTo")
  createdLeads       CrmLead[]     @relation("LeadCreatedBy")
  pipelineTasks      CrmTask[]     @relation("TaskAssignedTo")
  pipelineMeetings   CrmMeeting[]  @relation("MeetingEmployee")
  pipelineActivities CrmActivity[] @relation("ActivityPerformedBy")
  pipelineNotes      CrmNote[]     @relation("NoteAuthor")

  // ── Daily Activity & Productivity (Phase W1, draft schema, 2026-06-25) ──
  dailyActivityLogs             DailyActivityLog[]               @relation("DailyActivityLogEmployee")
  dailyActivitySummaries        DailyActivitySummary[]            @relation("DailyActivitySummaryEmployee")
  dailyActivitySummariesReopened DailyActivitySummary[]           @relation("DailyActivitySummaryReopenedBy")
  dailyActivityCorrectionsRaised  DailyActivityCorrectionRequest[] @relation("CorrectionRequestEmployee")
  dailyActivityCorrectionsManaged DailyActivityCorrectionRequest[] @relation("CorrectionRequestManager")
  dailyProductivityScores         DailyProductivityScore[]        @relation("ProductivityScoreEmployee")

  // â"€â"€ Finance Operations Module (Phase 1) â"€â"€
  ledgerEntries            Ledger[]          @relation("LedgerRecordedBy")
  expenses                 Expense[]         @relation("ExpenseEmployee")
  expensesApproved         Expense[]         @relation("ExpenseApprovedBy")
  vouchersCreated          Voucher[]         @relation("VoucherCreatedBy")
  employeeAdvances         EmployeeAdvance[] @relation("AdvanceEmployee")
  employeeAdvancesApproved EmployeeAdvance[] @relation("AdvanceApprovedBy")
  travelClaims             TravelClaim[]     @relation("TravelClaimEmployee")
  travelClaimsApproved     TravelClaim[]     @relation("TravelClaimApprovedBy")
  auditLogs                AuditLog[]        @relation("AuditPerformedBy")

  // â"€â"€ Admin Console Phase 2 (back-references â€" no DB columns on Employee) â"€â"€
  employeeProfile  EmployeeProfile?  @relation("ProfileEmployee")
  reporteeProfiles EmployeeProfile[] @relation("ProfileReportingManager")
  teamLeadOf       Team[]            @relation("TeamLead")
  userRoles        UserRole[]

  // â"€â"€ Phase 5 â€" Policy Engine (back-references â€" no DB columns on Employee) â"€â"€
  policiesCreated      Policy[]               @relation("PolicyCreatedBy")
  policiesApproved     Policy[]               @relation("PolicyApprovedBy")
  policyVersions       PolicyVersion[]        @relation("PolicyVersionCreatedBy")
  policyAudits         PolicyAudit[]          @relation("PolicyAuditPerformedBy")
  configVersionsChanged  ConfigurationVersion[] @relation("ConfigVersionChangedBy")
  configVersionsReviewed ConfigurationVersion[] @relation("ConfigVersionReviewedBy")

  // â"€â"€ Phase 6 â€" Workflow Engine (back-references â€" no DB columns on Employee) â"€â"€
  workflowsCreated     WorkflowDefinition[] @relation("WorkflowCreatedBy")
  approvalRequests     ApprovalRequest[]    @relation("WorkflowRequestedBy")
  approvalActions      ApprovalAction[]     @relation("ApprovalActionBy")
  delegationsFrom      DelegationRule[]     @relation("DelegationFrom")
  delegationsTo        DelegationRule[]     @relation("DelegationTo")
  escalationTargets    EscalationRule[]     @relation("EscalationTarget")
  workflowAuditLogs    WorkflowAuditLog[]   @relation("WorkflowAuditActor")

  // â"€â"€ Phase 7 â€" Master Data Management (back-references â€" no DB columns on Employee) â"€â"€
  masterAudits  MasterAudit[] @relation("MasterAuditPerformedBy")

  @@index([reportsToId])
}

model KRA {
  id          Int      @id @default(autoincrement())
  title       String
  description String   @db.Text
  target      String   @db.Text
  deadline    DateTime
  weight      Int      @default(100)
  status      String   @default("active")
  createdAt   DateTime @default(now())
  employee    Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId  Int

  reviews        WeeklyReview[]
  weeklyCommits  WeeklyCommit[]
  certifications Certification[]

  @@index([employeeId])
}

model WeeklyReview {
  id         Int      @id @default(autoincrement())
  week       Int
  year       Int
  progress   Int
  score      Int
  notes      String   @db.Text
  blockers   String   @default("") @db.Text
  createdAt  DateTime @default(now())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId      Int

  @@index([employeeId])
  @@index([kraId])
}

model LeadGeneration {
  id             Int       @id @default(autoincrement())
  date           DateTime  @default(now())
  employee       Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId     Int
  territory      String    @default("")
  leadSource     String    @default("")
  customerName   String
  customer       Customer? @relation("LeadGenerationCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerId     Int?
  contactPerson  String    @default("")
  phoneEmail     String    @default("")
  activityType   String    @default("")
  activityCount  Int       @default(1)
  leadStatus     String    @default("New")
  qualifiedFlag  Boolean   @default(false)
  nextActionDate DateTime?
  remarks        String    @default("") @db.Text
  createdAt      DateTime  @default(now())

  @@index([employeeId])
  @@index([customerId])
}

model SalesFunnel {
  id                Int       @id @default(autoincrement())
  opportunityId     String    @default("")
  createdDate       DateTime  @default(now())
  employee          Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId        Int
  territory         String    @default("")
  customerName      String
  customer          Customer? @relation("SalesFunnelCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerId        Int?
  solutionCategory  String    @default("")
  opportunityName   String
  stage             String    @default("Lead")
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field names still say "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  dealValueLakhs    Decimal   @default(0) @db.Decimal(18, 2)
  billingValueLakhs Decimal   @default(0) @db.Decimal(18, 2)
  grossProfitPct    Float     @default(0)
  proposalDate      DateTime?
  expectedCloseDate DateTime?
  poDate            DateTime?
  closedDate        DateTime?
  probabilityPct    Float     @default(0)
  status            String    @default("Active")
  newCustomerFlag   Boolean   @default(false)
  pocFlag           Boolean   @default(false)
  remarks           String    @default("") @db.Text
  createdAt         DateTime  @default(now())
  crmOpportunityId  Int?      // set when this legacy deal is promoted to a real CrmOpportunity

  @@index([employeeId])
  @@index([stage, status])
  @@index([customerId])
}

model Collection {
  id                    Int       @id @default(autoincrement())
  invoiceDate           DateTime  @default(now())
  invoiceNo             String    @default("")
  employee              Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId            Int
  customerName          String
  customer              Customer? @relation("CollectionCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerId            Int?
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field names still say "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  invoiceValueLakhs     Decimal   @db.Decimal(18, 2)
  amountWithoutGstLakhs Decimal   @default(0) @db.Decimal(18, 2)
  dueDate               DateTime
  paymentReceivedDate   DateTime?
  amountReceivedLakhs   Decimal   @default(0) @db.Decimal(18, 2)
  collectionStatus      String    @default("Pending")
  remarks               String    @default("") @db.Text
  createdAt             DateTime  @default(now())
  deletedAt             DateTime?
  deletedById           Int?
  deleteReason          String?   @db.Text

  payments Payment[]

  @@index([employeeId])
  @@index([collectionStatus])
  @@index([dueDate])
  @@index([customerId])
  @@index([deletedAt])
}

model Payment {
  id            Int        @id @default(autoincrement())
  collection    Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  collectionId  Int
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field name still says "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  amountLakhs   Decimal    @db.Decimal(18, 2)
  paymentDate   DateTime   @default(now())
  mode          String     @default("Bank Transfer")
  referenceNo   String     @default("")
  notes         String     @default("") @db.Text
  fromAdvanceId Int?
  recordedBy    Employee   @relation("PaymentRecordedBy", fields: [recordedById], references: [id])
  recordedById  Int
  createdAt     DateTime   @default(now())
  deletedAt     DateTime?
  deletedById   Int?
  deleteReason  String?    @db.Text

  @@index([collectionId])
  @@index([paymentDate])
  @@index([recordedById])
  @@index([deletedAt])
}

model OrderAdvance {
  id                    Int       @id @default(autoincrement())
  salesFunnelId         Int?
  customerName          String
  customer              Customer? @relation("OrderAdvanceCustomer", fields: [customerId], references: [id], onDelete: SetNull)
  customerId            Int?
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field name still says "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  amountLakhs           Decimal   @db.Decimal(18, 2)
  receivedDate          DateTime  @default(now())
  mode                  String    @default("Bank Transfer")
  referenceNo           String    @default("")
  notes                 String    @default("") @db.Text
  status                String    @default("unapplied")
  appliedToCollectionId Int?
  appliedDate           DateTime?
  recordedBy            Employee  @relation("AdvanceRecordedBy", fields: [recordedById], references: [id])
  recordedById          Int

  createdAt DateTime @default(now())

  @@index([recordedById])
  @@index([status])
  @@index([customerId])
}

model Notification {
  id          Int      @id @default(autoincrement())
  recipient   Employee @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId Int
  type        String
  title       String
  body        String   @default("") @db.Text
  link        String   @default("")
  amountLakhs Float?
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([recipientId, isRead])
  @@index([createdAt])
}

model DailyUpdate {
  id                     Int      @id @default(autoincrement())
  date                   DateTime @default(now())
  employee               Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId             Int
  topUpdates             String   @db.Text
  keyMovement            String   @default("") @db.Text
  blockers               String   @default("") @db.Text
  topDealThisWeek        String   @default("") @db.Text
  managerSupportRequired Boolean  @default(false)
  updateStatus           String   @default("On Track")
  createdAt              DateTime @default(now())

  @@index([employeeId, date])
}

model WeeklyCommit {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int
  kra        KRA      @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId      Int
  week       Int
  year       Int
  commitText String   @default("") @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([employeeId, week, year])
  @@index([kraId])
}

model Certification {
  id            Int       @id @default(autoincrement())
  employee      Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId    Int
  kra           KRA       @relation(fields: [kraId], references: [id], onDelete: Cascade)
  kraId         Int
  certName      String
  issuingBody   String    @default("")
  dateObtained  DateTime
  expiryDate    DateTime?
  attachmentUrl String    @default("")
  status        String    @default("pending")
  approvedBy    Int?
  approvedAt    DateTime?
  remarks       String    @default("") @db.Text
  createdAt     DateTime  @default(now())

  @@index([employeeId])
  @@index([kraId])
}

model CrmLead {
  id            Int      @id @default(autoincrement())
  title         String
  companyName   String
  contactPerson String
  email         String   @default("")
  phone         String   @default("")
  source        String   @default("Direct")
  categoryId    String?
  categoryName  String   @default("")
  oemId         String?
  oemName       String   @default("")
  productId     String?
  productName   String   @default("")
  customerId    String?
  customerName  String   @default("")
  customerRefId Int?
  customerRef   Customer? @relation("CrmLeadCustomer", fields: [customerRefId], references: [id], onDelete: SetNull)
  stage         String   @default("NEW_LEAD")
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR —
  // see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  expectedValue Decimal  @default(0) @db.Decimal(18, 2)
  remarks       String   @default("") @db.Text
  assignedTo    Employee @relation("LeadAssignedTo", fields: [assignedToId], references: [id])
  assignedToId  Int
  createdBy     Employee @relation("LeadCreatedBy", fields: [createdById], references: [id])
  createdById   Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  opportunity CrmOpportunity?
  tasks       CrmTask[]
  meetings    CrmMeeting[]
  activities  CrmActivity[]
  notes       CrmNote[]

  @@index([assignedToId])
  @@index([createdById])
  @@index([stage])
  @@index([customerRefId])
}

model CrmOpportunity {
  id                  Int       @id @default(autoincrement())
  lead                CrmLead   @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId              Int       @unique
  stage               String    @default("PROPOSAL_SENT")
  // Decimal Release 2 (Step 3U, 2026-06-23): converted from Float ₹ Lakhs to actual ₹ INR —
  // see docs/database/DECIMAL_RELEASE2_COMBINED_SCOPE_SIGNOFF.md.
  value               Decimal   @default(0) @db.Decimal(18, 2)
  expectedClosureDate DateTime?
  probability         Int       @default(50)
  discountPct         Float     @default(0)   // discount % requested (0-100); triggers approval when > 0
  lostReason          String    @default("") @db.Text
  // Closed Won fields — required when stage → WON
  dealValueExTax      Decimal   @default(0) @db.Decimal(18, 2)   // deal value excluding tax, actual ₹ INR
  netProfitLakhs      Decimal   @default(0) @db.Decimal(18, 2)   // net profit (absolute, actual ₹ INR)
  poNumber            String    @default("")  // purchase order number
  poDate              DateTime?               // PO date
  status              String    @default("active")
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tasks      CrmTask[]
  meetings   CrmMeeting[]
  activities CrmActivity[]

  @@index([stage, status])
}

model CrmTask {
  id            Int             @id @default(autoincrement())
  title         String
  description   String          @default("") @db.Text
  dueDate       DateTime
  assignedTo    Employee        @relation("TaskAssignedTo", fields: [assignedToId], references: [id])
  assignedToId  Int
  status        String          @default("pending")
  priority      String          @default("medium")
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  @@index([assignedToId])
  @@index([leadId])
  @@index([opportunityId])
}

model CrmMeeting {
  id            Int             @id @default(autoincrement())
  title         String
  meetingDate   DateTime
  notes         String          @default("") @db.Text
  attendees     String          @default("") @db.Text
  location      String          @default("")
  // Daily Activity & Productivity (Phase W1, 2026-06-25): added so meeting completion can be
  // detected as a Raw status → COMPLETED transition, the same pattern CrmTask already uses
  // for task_completed. No capture logic added yet — schema only. See
  // docs/webapp/DAILY_ACTIVITY_SCHEMA_DESIGN_REVIEW.md.
  status        String          @default("SCHEDULED") // SCHEDULED|COMPLETED|CANCELLED|RESCHEDULED
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?
  employee      Employee        @relation("MeetingEmployee", fields: [employeeId], references: [id])
  employeeId    Int
  createdAt     DateTime        @default(now())

  @@index([leadId])
  @@index([opportunityId])
  @@index([employeeId])
  @@index([status])
}

model CrmActivity {
  id            Int             @id @default(autoincrement())
  entityType    String
  entityId      Int
  action        String
  description   String          @default("") @db.Text
  meta          String          @default("") @db.Text
  performedBy   Employee        @relation("ActivityPerformedBy", fields: [performedById], references: [id])
  performedById Int
  timestamp     DateTime        @default(now())
  lead          CrmLead?        @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId        Int?
  opportunity   CrmOpportunity? @relation(fields: [opportunityId], references: [id], onDelete: Cascade)
  opportunityId Int?

  @@index([leadId])
  @@index([opportunityId])
  @@index([performedById])
  @@index([timestamp])
}

model CrmNote {
  id        Int      @id @default(autoincrement())
  content   String   @db.Text
  lead      CrmLead  @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    Int
  author    Employee @relation("NoteAuthor", fields: [authorId], references: [id])
  authorId  Int
  createdAt DateTime @default(now())

  @@index([leadId])
  @@index([authorId])
}

// ── Daily Activity & Productivity — webapp replacement for DailyUpdate (Phase W1, 2026-06-25) ──
// Draft schema only — see docs/webapp/DAILY_ACTIVITY_SCHEMA_DESIGN_REVIEW.md.
// Follows existing project convention: no Prisma `enum` types anywhere in this schema; status/
// type vocabularies are plain `String` columns with a default + inline comment listing allowed
// values (see CrmLead.stage, CrmTask.status, DailyUpdate.updateStatus, ApprovalRule.entityType
// for precedent). The vocabularies below mirror the enum lists requested in planning, expressed
// the same way the rest of this schema already expresses them.
// No DailyActivityAuditLog model — manager/admin actions on this system (correction
// approve/reject, day reopen, rule/target changes) reuse the existing AuditLog model below with
// entityType: "daily_activity_summary" | "daily_activity_correction" | "productivity_rule" |
// "productivity_role_target".

model DailyActivityLog {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation("DailyActivityLogEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int

  activityDate DateTime @db.Date

  // QUALIFIED_LEAD_CREATED|LEAD_UPDATED|FOLLOW_UP_ADDED|TASK_UPDATED|TASK_COMPLETED|
  // MEETING_SCHEDULED|MEETING_COMPLETED|PROPOSAL_SENT|OPPORTUNITY_UPDATED|CALL_NOTE_ADDED|
  // EMAIL_NOTE_ADDED|WHATSAPP_NOTE_ADDED|END_OF_DAY_SUMMARY_SUBMITTED
  activityType String

  // CRM_ACTIVITY|LEAD|TASK|MEETING|OPPORTUNITY|PROPOSAL|FOLLOW_UP|NOTE|SUMMARY|CORRECTION
  sourceType   String
  sourceId     Int?
  sourceTable  String  @default("")
  sourceAction String  @default("")

  points Int @default(0)

  // CAPTURED|COUNTED|EXCLUDED|CORRECTION_PENDING|CORRECTION_APPROVED|CORRECTION_REJECTED
  status String @default("CAPTURED")

  capturedAt DateTime  @default(now())
  countedAt  DateTime?

  isCorrection        Boolean                         @default(false)
  correctionRequest   DailyActivityCorrectionRequest? @relation("CorrectionGeneratedLog", fields: [correctionRequestId], references: [id], onDelete: SetNull)
  correctionRequestId Int?

  metadataJson String @default("") @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  disputedByCorrections DailyActivityCorrectionRequest[] @relation("CorrectionDisputedLog")

  @@index([employeeId, activityDate])
  @@index([activityType])
  @@index([sourceType, sourceId])
  @@index([correctionRequestId])
  // Duplicate-prevention: blocks the same employee from logging the identical
  // (sourceType, sourceId, sourceAction) event twice on the same day — see
  // docs/webapp/DAILY_ACTIVITY_SCHEMA_DESIGN_REVIEW.md §9 for why this is "once per day" rather
  // than "once ever" (an entity like an Opportunity can legitimately update more than once
  // across different days), and for the documented application-level gap (this constraint
  // cannot by itself distinguish two distinct same-day transitions on the same entity from a
  // retried duplicate of one transition — sourceAction must encode enough detail, e.g. the
  // specific stage pair, for that distinction to hold).
  @@unique([employeeId, sourceType, sourceId, sourceAction, activityDate], name: "uq_activity_log_event_per_day")
}

model DailyActivitySummary {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation("DailyActivitySummaryEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int

  summaryDate DateTime @db.Date

  // NO_ACTIVITY|SUMMARY_PENDING|INCOMPLETE|CLOSED|REOPENED|LATE_SUBMITTED|PENDING_CORRECTION
  status String @default("NO_ACTIVITY")

  // NO_ACTIVITY|LOW_ACTIVITY|ACTIVE|PRODUCTIVE|HIGHLY_PRODUCTIVE — this is the one field
  // employees see; managers additionally see totalPoints. No separate "employeeVisibleBand"
  // column — it would only ever duplicate this value, see design review doc §4.
  productivityBand String @default("NO_ACTIVITY")
  totalPoints      Int    @default(0)

  autoSummaryJson String @default("") @db.Text
  blockers        String @default("") @db.Text
  nextDayPlan     String @default("") @db.Text
  finalRemarks    String @default("") @db.Text

  submittedAt DateTime?
  closedAt    DateTime?
  lockedAt    DateTime?

  reopenedAt   DateTime?
  reopenedBy   Employee? @relation("DailyActivitySummaryReopenedBy", fields: [reopenedById], references: [id], onDelete: SetNull)
  reopenedById Int?

  lateSubmittedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  correctionRequests DailyActivityCorrectionRequest[] @relation("CorrectionSummary")

  @@unique([employeeId, summaryDate])
  @@index([status])
  @@index([summaryDate])
  @@index([reopenedById])
}

model DailyActivityCorrectionRequest {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation("CorrectionRequestEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int

  summary   DailyActivitySummary @relation("CorrectionSummary", fields: [summaryId], references: [id], onDelete: Cascade)
  summaryId Int

  // The originally-captured log entry being disputed as wrong, if any — null when the
  // correction is for a *missing* activity (nothing was captured to reference).
  activityLog   DailyActivityLog? @relation("CorrectionDisputedLog", fields: [activityLogId], references: [id], onDelete: SetNull)
  activityLogId Int?

  requestedActivityType String  @default("")
  requestedSourceType   String  @default("")
  requestedSourceId     Int?
  reason                String  @db.Text

  // PENDING|APPROVED|REJECTED|CANCELLED
  status String @default("PENDING")

  manager           Employee? @relation("CorrectionRequestManager", fields: [managerId], references: [id], onDelete: SetNull)
  managerId         Int?
  managerDecisionAt DateTime?
  managerRemarks    String    @default("") @db.Text
  approvedPoints    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // The log entry created as a result of this correction being approved (e.g. backfilling a
  // missing activity). Distinct relation from `activityLog` above — that one points at the
  // disputed/original entry, this one points at what the approval generated.
  generatedLog DailyActivityLog[] @relation("CorrectionGeneratedLog")

  @@index([summaryId, status])
  @@index([employeeId, status])
  @@index([activityLogId])
  @@index([managerId])
}

model DailyProductivityScore {
  id         Int      @id @default(autoincrement())
  employee   Employee @relation("ProductivityScoreEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  employeeId Int

  // DAILY|WEEKLY|MONTHLY
  periodType  String
  periodStart DateTime @db.Date
  periodEnd   DateTime @db.Date

  totalPoints       Int    @default(0)
  closedDays        Int    @default(0)
  incompleteDays    Int    @default(0)
  absentDays        Int    @default(0)
  productivityBand  String @default("NO_ACTIVITY")
  kraEligiblePoints Int    @default(0)

  qualityIndicatorJson String @default("") @db.Text

  generatedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Default Prisma-generated constraint name
  // ("DailyProductivityScore_employeeId_periodType_periodStart_periodEnd_key", 71 chars)
  // exceeds MySQL/MariaDB's 64-character identifier limit (found applying the draft migration
  // to dev, Phase W1B, 2026-06-25) — explicitly named shorter here.
  @@unique([employeeId, periodType, periodStart, periodEnd], name: "uq_daily_productivity_score_period")
  @@index([periodType, periodStart])
}

model ProductivityActivityRule {
  id           Int     @id @default(autoincrement())
  // Same vocabulary as DailyActivityLog.activityType.
  activityType String
  displayName  String  @default("")
  points       Int     @default(0)
  isActive     Boolean @default(true)

  // null = global default rule for this activityType; non-null = role-specific override.
  // See design review doc §11 for the open question on exact role-string values.
  appliesToRole String?
  effectiveFrom DateTime?
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([activityType, isActive])
}

model ProductivityRoleTarget {
  id Int @id @default(autoincrement())

  // Matches Employee.role free-text values (e.g. "Inside Sales", "BDE") — see design review
  // doc §11 for the open mapping question (no seeded role currently reads exactly "Sales
  // Manager").
  roleName String

  dailyTargetPoints   Int?
  weeklyTargetPoints  Int?
  monthlyTargetPoints Int?
  isActive            Boolean @default(true)

  effectiveFrom DateTime?
  effectiveTo   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roleName, isActive])
}

model Customer {
  id         Int        @id @default(autoincrement())
  name       String
  address    String     @default("") @db.Text
  district   String     @default("")
  state      String     @default("")
  pincode    String     @default("")
  gstNo      String     @default("")
  officeType String     @default("HO")
  parentId   Int?
  parent     Customer?  @relation("CustomerBranches", fields: [parentId], references: [id])
  branches   Customer[] @relation("CustomerBranches")
  crmSource  String     @default("")
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  deletedAt  DateTime?
  deletedById Int?
  deleteReason String?  @db.Text

  // Back-references from operational tables (Phase 17 + CRM)
  leadGenerations LeadGeneration[] @relation("LeadGenerationCustomer")
  salesFunnels    SalesFunnel[]    @relation("SalesFunnelCustomer")
  collections     Collection[]     @relation("CollectionCustomer")
  orderAdvances   OrderAdvance[]   @relation("OrderAdvanceCustomer")
  crmLeads        CrmLead[]        @relation("CrmLeadCustomer")

  @@index([parentId])
  @@index([name])
  @@index([deletedAt])
}

model AppSetting {
  id          Int      @id @default(autoincrement())
  category    String
  key         String   @unique
  label       String
  value       String   @db.Text
  description String   @default("") @db.Text
  updatedAt   DateTime @updatedAt
  updatedById Int?
}

model AppRole {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  label       String
  level       Int
  color       String   @default("#6b7280")
  isSystem    Boolean  @default(false)
  description String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  pageAccess RolePageAccess[]
}

model RolePageAccess {
  id        Int     @id @default(autoincrement())
  role      AppRole @relation(fields: [roleId], references: [id], onDelete: Cascade)
  roleId    Int
  pageKey   String
  canView   Boolean @default(false)
  canCreate Boolean @default(false)
  canEdit   Boolean @default(false)
  canDelete Boolean @default(false)

  @@unique([roleId, pageKey])
}

// ============================================================
// Finance Operations Module â€" Phase 1 (database only)
// Provider: mysql Â· money in â‚¹ Lakhs (Float -> DOUBLE) Â· long text uses @db.Text
// Every FK + hot-filter column is indexed. No API/UI in this phase.
// Module â†’ model map:
//   Account        -> FinAccount       (chart of accounts: cash + bank)
//   Ledger         -> Ledger           (general ledger entries)
//   Expense        -> Expense          (expense register; category + attachments inline)
//   Vendor         -> Vendor
//   Voucher        -> Voucher (+ VoucherSequence for atomic per-FY numbering)
//   EmployeeAdvance-> EmployeeAdvance
//   TravelClaim    -> TravelClaim      (local conveyance / travel reimbursement)
//   ApprovalRule   -> ApprovalRule     (configurable amount-limit approval policy)
//   AuditLog       -> AuditLog         (generic financial audit trail)
// ============================================================

// â"€â"€ Account: chart of accounts (cash & bank) â"€â"€
model FinAccount {
  id             Int      @id @default(autoincrement())
  name           String
  type           String   @default("cash") // "cash" | "bank"
  branchName     String   @default("HO")
  bankName       String   @default("")
  accountNo      String   @default("")
  ifscCode       String   @default("")
  accountHolder  String   @default("")
  openingBalance Float    @default(0)
  currentBalance Float    @default(0) // CACHED â€" written by the cash/bank service only
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  ledgerEntries Ledger[]

  @@index([type])
  @@index([isActive])
}

// â"€â"€ Ledger: general ledger entries posted against an account â"€â"€
model Ledger {
  id             Int        @id @default(autoincrement())
  account        FinAccount @relation(fields: [accountId], references: [id])
  accountId      Int
  entryDate      DateTime   @default(now())
  type           String // upi|cheque|neft|rtgs|imps|cash_in|cash_out|receipt|payment|bank_charge|transfer
  direction      String // "debit" | "credit"
  amountLakhs    Float
  narration      String     @default("") @db.Text
  referenceNo    String     @default("")
  chequeNo       String     @default("")
  chequeDate     DateTime?
  payee          String     @default("")
  voucher        Voucher?   @relation(fields: [voucherId], references: [id])
  voucherId      Int?
  pairedLedgerId Int? // soft self-pair for bank<->cash transfers
  reconciled     Boolean    @default(false)
  reconciledAt   DateTime?
  recordedBy     Employee   @relation("LedgerRecordedBy", fields: [recordedById], references: [id])
  recordedById   Int
  createdAt      DateTime   @default(now())

  @@index([accountId])
  @@index([entryDate])
  @@index([type])
  @@index([reconciled])
  @@index([voucherId])
  @@index([recordedById])
}

// â"€â"€ Vendor master â"€â"€
model Vendor {
  id            Int      @id @default(autoincrement())
  name          String
  gstin         String   @default("")
  pan           String   @default("")
  address       String   @default("") @db.Text
  city          String   @default("")
  state         String   @default("")
  pincode       String   @default("")
  contactName   String   @default("")
  contactPhone  String   @default("")
  contactEmail  String   @default("")
  bankName      String   @default("")
  bankAccountNo String   @default("")
  ifscCode      String   @default("")
  paymentTerms  String   @default("30 days")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?
  deletedById   Int?
  deleteReason  String?  @db.Text

  expenses Expense[]

  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
}

// â"€â"€ Expense register (category + attachments held inline for Phase 1) â"€â"€
model Expense {
  id              Int             @id @default(autoincrement())
  category        String          @default("") // category name (string kept for backward compat)
  categoryCode    String          @default("") // short code, e.g. TRVL
  expenseCategory ExpenseCategory? @relation("ExpenseCategory", fields: [expenseCategoryId], references: [id], onDelete: SetNull)
  expenseCategoryId Int?
  vendor          Vendor?   @relation(fields: [vendorId], references: [id])
  vendorId        Int?
  customerName    String    @default("") // denormalized customer tag (profitability)
  employee        Employee  @relation("ExpenseEmployee", fields: [employeeId], references: [id])
  employeeId      Int
  expenseDate     DateTime  @default(now())
  // Decimal Release 1 (Step 3Q, 2026-06-22): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field name still says "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE1_SIGNOFF_PLAN.md.
  amountLakhs     Decimal   @db.Decimal(18, 2)
  gstRate         Float     @default(0)
  gstAmountLakhs  Decimal   @default(0) @db.Decimal(18, 2)
  narration       String    @default("") @db.Text
  vendorInvoiceNo String    @default("")
  attachmentsJson String    @default("[]") @db.Text // JSON array of { fileName, fileUrl }
  status          String    @default("draft") // draft|submitted|approved|rejected|paid
  voucher         Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId       Int?
  approvedBy      Employee? @relation("ExpenseApprovedBy", fields: [approvedById], references: [id])
  approvedById    Int?
  approvedAt      DateTime?
  paidDate        DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?
  deletedById     Int?
  deleteReason    String?   @db.Text

  @@index([category])
  @@index([expenseCategoryId])
  @@index([vendorId])
  @@index([employeeId])
  @@index([expenseDate])
  @@index([status])
  @@index([customerName])
  @@index([voucherId])
  @@index([deletedAt])
}

// â"€â"€ Voucher â"€â"€
model Voucher {
  id          Int       @id @default(autoincrement())
  voucherNo   String    @unique // CI/26-27/00001
  type        String // payment|receipt|journal|expense|conveyance|advance
  voucherDate DateTime  @default(now())
  amountLakhs Float
  narration   String    @default("") @db.Text
  status      String    @default("draft") // draft|approved|voided
  pdfUrl      String    @default("") @db.Text
  voidedAt    DateTime?
  voidReason  String    @default("") @db.Text
  createdBy   Employee  @relation("VoucherCreatedBy", fields: [createdById], references: [id])
  createdById Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ledgerEntries Ledger[]
  expenses      Expense[]
  travelClaims  TravelClaim[]
  advances      EmployeeAdvance[]

  @@index([voucherDate])
  @@index([type])
  @@index([status])
  @@index([createdById])
}

// â"€â"€ Voucher sequence: atomic per-financial-year numbering (supports Voucher) â"€â"€
model VoucherSequence {
  id            Int      @id @default(autoincrement())
  financialYear String   @unique // "26-27"
  lastNumber    Int      @default(0)
  updatedAt     DateTime @updatedAt
}

// â"€â"€ Employee advance â"€â"€
model EmployeeAdvance {
  id                   Int       @id @default(autoincrement())
  advanceNo            String    @unique // CI/ADV/26-27/00001
  employee             Employee  @relation("AdvanceEmployee", fields: [employeeId], references: [id])
  employeeId           Int
  category             String    @default("Other") // Customer Project|Travel|Office Supplies|Training|Medical|Other
  purpose              String    @default("") @db.Text
  // Decimal Release 1 (Step 3Q, 2026-06-22): converted from Float ₹ Lakhs to actual ₹ INR.
  // Field names still say "Lakhs" (rename deferred) — see docs/database/DECIMAL_RELEASE1_SIGNOFF_PLAN.md.
  amountLakhs          Decimal   @db.Decimal(18, 2)
  requestDate          DateTime  @default(now())
  requiredByDate       DateTime?
  status               String    @default("pending") // pending|approved|disbursed|settled|rejected
  approvedBy           Employee? @relation("AdvanceApprovedBy", fields: [approvedById], references: [id])
  approvedById         Int?
  approvedAt           DateTime?
  disbursedDate        DateTime?
  disbursedAmountLakhs Decimal?  @db.Decimal(18, 2)
  disbursedFromType    String    @default("") // "cash" | "bank"
  disbursedFromId      Int? // soft ref to FinAccount.id
  settledDate          DateTime?
  settledAmountLakhs   Decimal?  @db.Decimal(18, 2)
  balanceLakhs         Decimal   @default(0) @db.Decimal(18, 2) // CACHED: disbursed âˆ’ settled
  voucher              Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId            Int?
  remarks              String    @default("") @db.Text
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?
  deletedById          Int?
  deleteReason         String?   @db.Text

  @@index([employeeId])
  @@index([status])
  @@index([requestDate])
  @@index([voucherId])
  @@index([deletedAt])
}

// â"€â"€ Travel claim: local conveyance / travel reimbursement (GPS-aware) â"€â"€
model TravelClaim {
  id           Int       @id @default(autoincrement())
  claimNo      String    @unique // CI/TRV/26-27/00001
  employee     Employee  @relation("TravelClaimEmployee", fields: [employeeId], references: [id])
  employeeId   Int
  travelDate   DateTime  @default(now())
  fromLocation String    @default("") @db.Text
  toLocation   String    @default("") @db.Text
  fromLat      Float?
  fromLng      Float?
  toLat        Float?
  toLng        Float?
  distanceKm   Float     @default(0)
  mode         String    @default("bike") // bike|car|auto|public
  // Decimal Release 1 (Step 3Q, 2026-06-22): ratePerKm/amountRupees were already actual INR
  // (no value transformation); amountLakhs converted from Float ₹ Lakhs to actual ₹ INR
  // (field name still says "Lakhs", rename deferred) — see
  // docs/database/DECIMAL_RELEASE1_SIGNOFF_PLAN.md.
  ratePerKm    Decimal   @default(0) @db.Decimal(10, 4) // â‚¹ per km (snapshot from HR policy)
  amountRupees Decimal   @default(0) @db.Decimal(18, 2)
  amountLakhs  Decimal   @default(0) @db.Decimal(18, 2)
  purpose      String    @default("") @db.Text
  status       String    @default("draft") // draft|submitted|approved|rejected|paid
  approvedBy   Employee? @relation("TravelClaimApprovedBy", fields: [approvedById], references: [id])
  approvedById Int?
  approvedAt   DateTime?
  voucher      Voucher?  @relation(fields: [voucherId], references: [id])
  voucherId    Int?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?
  deletedById  Int?
  deleteReason String?   @db.Text

  @@index([employeeId])
  @@index([travelDate])
  @@index([status])
  @@index([voucherId])
  @@index([deletedAt])
}

// â"€â"€ Approval rule: configurable amount-limit approval policy â"€â"€
model ApprovalRule {
  id               Int      @id @default(autoincrement())
  name             String
  entityType       String   @default("all") // all|expense|advance|travel|voucher
  autoApproveLimit Float    @default(0)
  level1Limit      Float    @default(0)
  level1Role       String   @default("")
  level2Limit      Float?
  level2Role       String?
  level3Limit      Float?
  level3Role       String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([entityType])
  @@index([isActive])
}

// â"€â"€ Audit log: generic financial audit trail â"€â"€
model AuditLog {
  id            Int      @id @default(autoincrement())
  entityType    String // expense|voucher|ledger|account|advance|travel_claim|vendor|approval
  entityId      Int
  action        String // create|update|submit|approve|reject|void|disburse|settle|delete|reconcile
  performedBy   Employee @relation("AuditPerformedBy", fields: [performedById], references: [id])
  performedById Int
  changes       String   @default("") @db.Text // JSON before/after or detail
  notes         String   @default("") @db.Text
  createdAt     DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([action])
  @@index([createdAt])
}

// Finance Administration Engine - Phase 9
// 8 models: FinancePolicy, ExpenseCategory, ExpenseLimitRule, ConveyancePolicy,
// AdvancePolicy, CustomerCreditPolicy, VoucherConfiguration, CollectionPolicy

model FinancePolicy {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  policyName  String
  policyType  String
  policyCode  String   @default("")
  description String   @default("") @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([companyId])
  @@index([policyType])
  @@index([status])
  @@map("finance_policy")
}

model ExpenseCategory {
  id               Int      @id @default(autoincrement())
  companyId        Int?
  name             String
  code             String   @unique
  description      String   @default("") @db.Text
  requiresReceipt  Boolean  @default(false)
  requiresApproval Boolean  @default(false)
  parentId         Int?
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  parent     ExpenseCategory?   @relation("CatParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   ExpenseCategory[]  @relation("CatParent")
  limitRules ExpenseLimitRule[]
  expenses   Expense[]          @relation("ExpenseCategory")

  @@index([companyId])
  @@index([parentId])
  @@index([status])
  @@map("expense_category")
}

model ExpenseLimitRule {
  id                Int             @id @default(autoincrement())
  expenseCategory   ExpenseCategory @relation(fields: [expenseCategoryId], references: [id], onDelete: Cascade)
  expenseCategoryId Int
  scopeType         String
  scopeId           String
  dailyLimit        Float           @default(0)
  monthlyLimit      Float           @default(0)
  yearlyLimit       Float           @default(0)
  policyCode        String          @default("")
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@index([expenseCategoryId])
  @@index([scopeType, scopeId])
  @@map("expense_limit_rule")
}

model ConveyancePolicy {
  id                       Int      @id @default(autoincrement())
  companyId                Int?
  vehicleType              String
  ratePerKm                Float    @default(0)
  monthlyLimitRupees       Float    @default(0)
  googleMapRequired        Boolean  @default(false)
  allowManualOverride      Boolean  @default(true)
  overrideApprovalRequired Boolean  @default(false)
  status                   String   @default("active")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@index([companyId])
  @@index([vehicleType])
  @@index([status])
  @@map("conveyance_policy")
}

model AdvancePolicy {
  id               Int      @id @default(autoincrement())
  companyId        Int?
  maxAdvanceLakhs  Float    @default(0)
  settlementDays   Int      @default(30)
  approvalRequired Boolean  @default(true)
  policyCode       String   @default("")
  status           String   @default("active")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([companyId])
  @@map("advance_policy")
}

model CustomerCreditPolicy {
  id                      Int      @id @default(autoincrement())
  companyId               Int?
  customerType            String   @default("STANDARD")
  defaultCreditLimitLakhs Float    @default(0)
  maxCreditLimitLakhs     Float    @default(0)
  approvalAboveLimit      Boolean  @default(true)
  paymentTermsDays        Int      @default(30)
  status                  String   @default("active")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
  @@index([customerType])
  @@map("customer_credit_policy")
}

model VoucherConfiguration {
  id                 Int      @id @default(autoincrement())
  companyId          Int?
  voucherType        String
  prefix             String   @default("")
  numberFormat       String   @default("PREFIX-YEAR-SEQ")
  runningNumber      Int      @default(0)
  financialYearReset Boolean  @default(true)
  financialYear      String   @default("")
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([companyId])
  @@index([voucherType])
  @@map("voucher_configuration")
}

model CollectionPolicy {
  id             Int      @id @default(autoincrement())
  companyId      Int?
  reminderDays   Int      @default(7)
  escalationDays Int      @default(14)
  creditHoldDays Int      @default(30)
  policyCode     String   @default("")
  status         String   @default("active")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([companyId])
  @@map("collection_policy")
}

// ============================================================
// Admin Console — Phase 2 Foundation
// Org Structure Â· Employee Profile Extension Â· Enterprise RBAC
// Provider: mysql Â· All String long-text â†’ @db.Text
// Every FK + filter column is indexed. No workflow/finance yet.
// ============================================================

// â"€â"€ 1. Tenant â€" top-level organisation group â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Tenant {
  id        Int       @id @default(autoincrement())
  name      String
  code      String    @unique
  status    String    @default("ACTIVE")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  companies Company[]
  roles     Role[]

  @@index([status])
}

// â"€â"€ 2. Company â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Company {
  id          Int      @id @default(autoincrement())
  tenantId    Int
  companyName String
  legalName   String   @default("")
  companyCode String   @default("")
  gstNumber   String   @default("")
  panNumber   String   @default("")
  email       String   @default("")
  phone       String   @default("")
  website     String   @default("")
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant           Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branches         Branch[]
  departments      Department[]
  designations     Designation[]
  employeeProfiles EmployeeProfile[]

  @@index([tenantId])
  @@index([status])
}

// â"€â"€ 3. Branch â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Branch {
  id         Int      @id @default(autoincrement())
  companyId  Int
  branchName String
  branchCode String   @default("")
  address    String   @default("") @db.Text
  city       String   @default("")
  state      String   @default("")
  country    String   @default("India")
  timezone   String   @default("Asia/Kolkata")
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// â"€â"€ 4. Department â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Department {
  id          Int      @id @default(autoincrement())
  companyId   Int
  name        String
  code        String   @default("")
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  teams            Team[]
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// â"€â"€ 5. Team â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Team {
  id           Int      @id @default(autoincrement())
  departmentId Int
  name         String
  teamLeadId   Int?
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  department       Department        @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  teamLead         Employee?         @relation("TeamLead", fields: [teamLeadId], references: [id], onDelete: SetNull)
  employeeProfiles EmployeeProfile[]

  @@index([departmentId])
  @@index([teamLeadId])
  @@index([status])
}

// â"€â"€ 6. Designation â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model Designation {
  id          Int      @id @default(autoincrement())
  companyId   Int
  title       String
  level       Int      @default(1)
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company          Company           @relation(fields: [companyId], references: [id], onDelete: Restrict)
  employeeProfiles EmployeeProfile[]

  @@index([companyId])
  @@index([status])
}

// â"€â"€ 7. EmployeeProfile â€" enterprise HR record (extends Employee) â"€â"€
// employmentStatus: DRAFT | ACTIVE | SUSPENDED | INACTIVE
model EmployeeProfile {
  id                 Int       @id @default(autoincrement())
  userId             Int       @unique // FK â†’ Employee.id (Employee IS the auth user)
  employeeCode       String    @default("")
  companyId          Int?
  branchId           Int?
  departmentId       Int?
  teamId             Int?
  designationId      Int?
  reportingManagerId Int?
  joiningDate        DateTime?
  employmentStatus   String    @default("ACTIVE")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  employee          Employee     @relation("ProfileEmployee", fields: [userId], references: [id], onDelete: Cascade)
  company           Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)
  branch            Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  department        Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  team              Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)
  designation       Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)
  reportingManager  Employee?    @relation("ProfileReportingManager", fields: [reportingManagerId], references: [id], onDelete: SetNull)
  employeeTargets   EmployeeTarget[]

  @@index([companyId])
  @@index([branchId])
  @@index([departmentId])
  @@index([teamId])
  @@index([designationId])
  @@index([reportingManagerId])
  @@index([employmentStatus])
}

// â"€â"€ 8. Role â€" enterprise role (additive; AppRole legacy kept) â"€â"€
// isSystemRole: true means not deletable via UI
model Role {
  id           Int      @id @default(autoincrement())
  tenantId     Int?
  name         String
  description  String   @default("") @db.Text
  level        Int      @default(1)
  isSystemRole Boolean  @default(false)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant            Tenant?            @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  rolePermissions   RolePermission[]
  userRoles         UserRole[]
  dataAccessPolicies DataAccessPolicy[]

  @@index([tenantId])
  @@index([status])
}

// â"€â"€ 9. Permission â€" granular action catalogue â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// Unique per (module, resource, action) â€" same across all tenants.
model Permission {
  id          Int    @id @default(autoincrement())
  module      String // CRM | Finance | Workflow | Settings | Reports | Masters
  resource    String // Lead | Opportunity | Expense | Invoice | ...
  action      String // VIEW | CREATE | EDIT | DELETE | APPROVE | EXPORT | IMPORT | ASSIGN
  description String @default("") @db.Text

  rolePermissions RolePermission[]

  @@unique([module, resource, action])
  @@index([module])
}

// â"€â"€ 10. RolePermission â€" grants permission to a role â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model RolePermission {
  id           Int        @id @default(autoincrement())
  roleId       Int
  permissionId Int
  createdAt    DateTime   @default(now())

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

// â"€â"€ 11. UserRole â€" multiple roles per employee â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int      // FK â†’ Employee.id
  roleId    Int
  createdAt DateTime @default(now())

  employee  Employee @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

// â"€â"€ 12. DataAccessPolicy â€" per-role data visibility scope â"€â"€â"€â"€â"€
// scope: OWN | TEAM | DEPARTMENT | BRANCH | COMPANY | ALL
// filterJson: optional JSON string for additional WHERE constraints
model DataAccessPolicy {
  id         Int      @id @default(autoincrement())
  roleId     Int
  module     String   @default("")
  scope      String   @default("OWN")
  filterJson String?  @db.Text
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([roleId, module])
  @@index([roleId])
  @@index([scope])
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// Phase 5 â€" Policy Engine
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

// â"€â"€ 13. PolicyCategory â€" groups policies by domain â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model PolicyCategory {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  policies Policy[]

  @@index([status])
}

// â"€â"€ 14. Policy â€" a versioned, lifecycle-managed business rule â"€
// scopeType: GLOBAL | COMPANY | BRANCH | DEPARTMENT | ROLE | USER
// status:    DRAFT | REVIEW | ACTIVE | INACTIVE | ARCHIVED
model Policy {
  id            Int       @id @default(autoincrement())
  categoryId    Int
  name          String
  code          String    @unique
  description   String    @default("") @db.Text
  scopeType     String    @default("GLOBAL")
  scopeId       Int?
  status        String    @default("DRAFT")
  version       Int       @default(1)
  effectiveFrom DateTime?
  effectiveTo   DateTime?
  createdBy     Int
  approvedBy    Int?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  category PolicyCategory @relation(fields: [categoryId], references: [id])
  creator  Employee       @relation("PolicyCreatedBy",  fields: [createdBy],  references: [id])
  approver Employee?      @relation("PolicyApprovedBy", fields: [approvedBy], references: [id])

  rules    PolicyRule[]
  versions PolicyVersion[]
  audits   PolicyAudit[]

  @@index([categoryId])
  @@index([status])
  @@index([scopeType, scopeId])
}

// â"€â"€ 15. PolicyRule â€" individual IF/THEN rule inside a policy â"€â"€
model PolicyRule {
  id            Int      @id @default(autoincrement())
  policyId      Int
  ruleName      String
  priority      Int      @default(10)
  conditionJson String   @db.Text  // JSON: { field, operator, value } or { and/or: [...] }
  actionJson    String   @db.Text  // JSON: { type, ...params }
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  policy Policy @relation(fields: [policyId], references: [id], onDelete: Cascade)

  @@index([policyId])
  @@index([priority])
}

// â"€â"€ 16. PolicyVersion â€" immutable snapshot per publish cycle â"€â"€
model PolicyVersion {
  id            Int      @id @default(autoincrement())
  policyId      Int
  versionNumber Int
  snapshotJson  String   @db.Text  // full Policy + rules JSON at publish time
  changeReason  String   @default("") @db.Text
  createdBy     Int
  createdAt     DateTime @default(now())

  policy  Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  creator Employee @relation("PolicyVersionCreatedBy", fields: [createdBy], references: [id])

  @@unique([policyId, versionNumber])
  @@index([policyId])
}

// â"€â"€ 17. PolicyAudit â€" every change to a policy â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model PolicyAudit {
  id          Int      @id @default(autoincrement())
  policyId    Int
  action      String   // CREATED | UPDATED | STATUS_CHANGED | RULE_ADDED | RULE_REMOVED | PUBLISHED | ARCHIVED
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  policy    Policy   @relation(fields: [policyId], references: [id], onDelete: Cascade)
  performer Employee @relation("PolicyAuditPerformedBy", fields: [performedBy], references: [id])

  @@index([policyId])
  @@index([performedBy])
}

// â"€â"€ 18. ConfigurationVersion â€" Draftâ†’Reviewâ†’Published settings â"€
// Enables lifecycle management for AppSetting values.
// getSetting() reads the latest published version; falls back to AppSetting row.
model ConfigurationVersion {
  id           Int       @id @default(autoincrement())
  settingKey   String
  value        String    @db.Text  // JSON-encoded setting value
  version      Int
  module       String
  status       String    @default("draft")  // draft | in_review | published | rolled_back
  changedById  Int
  reviewedById Int?
  publishedAt  DateTime?
  note         String?   @db.Text
  createdAt    DateTime  @default(now())

  changedBy  Employee  @relation("ConfigVersionChangedBy",  fields: [changedById],  references: [id])
  reviewedBy Employee? @relation("ConfigVersionReviewedBy", fields: [reviewedById], references: [id])

  @@unique([settingKey, version])
  @@index([settingKey, status])
  @@index([changedById])
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// Phase 6 â€" Workflow Engine
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

// â"€â"€ 19. WorkflowDefinition â€" a named, versioned approval workflow â"€â"€
// status:  DRAFT | ACTIVE | INACTIVE
// module:  CRM | FINANCE | HR | SECURITY | MASTERS | WORKFLOW | PROCUREMENT | PROJECTS
model WorkflowDefinition {
  id            Int      @id @default(autoincrement())
  name          String
  code          String   @unique
  description   String   @default("") @db.Text
  module        String
  triggerEvent  String
  status        String   @default("DRAFT")
  conditionJson String?  @db.Text  // optional JSON condition for auto-trigger matching
  version       Int      @default(1)
  createdBy     Int
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  creator         Employee         @relation("WorkflowCreatedBy", fields: [createdBy], references: [id])
  steps           WorkflowStep[]
  requests        ApprovalRequest[]
  escalationRules EscalationRule[]

  @@map("workflow_definition")
  @@index([module, triggerEvent])
  @@index([status])
  @@index([createdBy])
}

// â"€â"€ 20. WorkflowStep â€" one level/step inside a workflow definition â"€â"€
// approvalType: USER | ROLE | REPORTING_MANAGER | DEPARTMENT_HEAD | POLICY_BASED
// approvalMode: SEQUENTIAL | PARALLEL
model WorkflowStep {
  id              Int      @id @default(autoincrement())
  workflowId      Int
  stepNumber      Int
  stepName        String
  approvalType    String   @default("REPORTING_MANAGER")
  approverId      Int?     // employee id (for USER type)
  approverRoleId  Int?     // role id (for ROLE type)
  approvalMode    String   @default("SEQUENTIAL")
  isMandatory     Boolean  @default(true)
  timeoutHours    Int      @default(24)
  requireComments Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workflow        WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  actions         ApprovalAction[]
  escalationRules EscalationRule[]

  @@map("workflow_step")
  @@index([workflowId])
  @@index([stepNumber])
}

// â"€â"€ 21. ApprovalRequest â€" a live approval in-flight for a business entity â"€â"€
// status: PENDING | APPROVED | REJECTED | RETURNED | CANCELLED
model ApprovalRequest {
  id          Int       @id @default(autoincrement())
  workflowId  Int
  entityType  String    // EXPENSE | DEAL | VENDOR | CUSTOMER | DISCOUNT | ADVANCE | etc.
  entityId    String    // string ID of the business entity
  requestedBy Int
  status      String    @default("PENDING")
  currentStep Int       @default(1)
  contextJson String?   @db.Text  // snapshot of entity data at submission
  submittedAt DateTime  @default(now())
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id])
  requester Employee           @relation("WorkflowRequestedBy", fields: [requestedBy], references: [id])
  actions   ApprovalAction[]

  @@map("approval_request")
  @@index([workflowId])
  @@index([requestedBy])
  @@index([status])
  @@index([entityType, entityId])
}

// â"€â"€ 22. ApprovalAction â€" a single action on a request (approve/reject/etc.) â"€â"€
// action: APPROVE | REJECT | RETURN | DELEGATE
model ApprovalAction {
  id         Int      @id @default(autoincrement())
  requestId  Int
  stepId     Int
  approverId Int
  action     String   // APPROVE | REJECT | RETURN | DELEGATE
  comments   String?  @db.Text
  toUserId   Int?     // target employee for DELEGATE action
  createdAt  DateTime @default(now())

  request  ApprovalRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  step     WorkflowStep    @relation(fields: [stepId],    references: [id])
  approver Employee        @relation("ApprovalActionBy",  fields: [approverId], references: [id])

  @@map("approval_action")
  @@index([requestId])
  @@index([stepId])
  @@index([approverId])
}

// â"€â"€ 23. DelegationRule â€" user delegates approval rights for a date range â"€â"€
// status: ACTIVE | INACTIVE | EXPIRED
model DelegationRule {
  id        Int      @id @default(autoincrement())
  fromUser  Int
  toUser    Int
  module    String?  // null = all modules
  startDate DateTime
  endDate   DateTime
  status    String   @default("ACTIVE")
  reason    String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  from Employee @relation("DelegationFrom", fields: [fromUser], references: [id])
  to   Employee @relation("DelegationTo",   fields: [toUser],   references: [id])

  @@map("delegation_rule")
  @@index([fromUser])
  @@index([toUser])
  @@index([status])
}

// â"€â"€ 24. EscalationRule â€" time-based escalation config for a step â"€â"€
// action: REMIND | ESCALATE | AUTO_APPROVE | AUTO_REJECT
model EscalationRule {
  id          Int      @id @default(autoincrement())
  workflowId  Int
  stepId      Int?     // null = any step in this workflow
  afterHours  Int      @default(24)
  escalateTo  Int?     // FK Employee (for ESCALATE action)
  action      String   @default("REMIND")
  repeatEvery Int?     // hours between repeats (for REMIND)
  maxTriggers Int      @default(3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow  WorkflowDefinition @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  step      WorkflowStep?      @relation(fields: [stepId],     references: [id])
  escalatee Employee?          @relation("EscalationTarget",   fields: [escalateTo], references: [id])

  @@map("escalation_rule")
  @@index([workflowId])
  @@index([stepId])
}

// â"€â"€ 25. WorkflowAuditLog â€" every lifecycle event in the workflow engine â"€â"€
// entityType: WORKFLOW_DEFINITION | APPROVAL_REQUEST
// action: CREATED | ASSIGNED | APPROVED | REJECTED | ESCALATED | DELEGATED | RETURNED | CANCELLED | COMPLETED
model WorkflowAuditLog {
  id         Int      @id @default(autoincrement())
  entityType String
  entityId   Int
  action     String
  actorId    Int
  details    String?  @db.Text  // JSON context
  createdAt  DateTime @default(now())

  actor Employee @relation("WorkflowAuditActor", fields: [actorId], references: [id])

  @@map("workflow_audit_log")
  @@index([entityType, entityId])
  @@index([actorId])
  @@index([createdAt])
}

// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•
// Phase 7 â€" Master Data Management
// â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•â•

// â"€â"€ 26. MasterCategory â€" groups master definitions by domain â"€â"€
model MasterCategory {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  status      String   @default("ACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  definitions MasterDefinition[]

  @@map("master_category")
  @@index([status])
}

// â"€â"€ 27. MasterDefinition â€" defines a named master (e.g. OEM, Industry) â"€â"€
model MasterDefinition {
  id                   Int     @id @default(autoincrement())
  categoryId           Int
  name                 String
  code                 String  @unique
  description          String  @default("") @db.Text
  allowCompanyOverride Boolean @default(true)
  allowBranchOverride  Boolean @default(false)
  requiresApproval     Boolean @default(false)
  status               String  @default("ACTIVE")
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  category        MasterCategory         @relation(fields: [categoryId], references: [id])
  values          MasterValue[]
  validationRules MasterValidationRule[]

  @@map("master_definition")
  @@index([categoryId])
  @@index([status])
}

// â"€â"€ 28. MasterValue â€" a single item inside a master â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
// code is unique per definition; parentId allows hierarchy (sub-categories)
model MasterValue {
  id                 Int     @id @default(autoincrement())
  masterDefinitionId Int
  parentId           Int?
  value              String
  code               String
  description        String  @default("") @db.Text
  metadataJson       String? @db.Text
  sortOrder          Int     @default(0)
  status             String  @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  definition MasterDefinition @relation(fields: [masterDefinitionId], references: [id], onDelete: Cascade)
  parent     MasterValue?     @relation("MasterValueParent", fields: [parentId], references: [id], onDelete: SetNull)
  children   MasterValue[]    @relation("MasterValueParent")
  overrides  MasterOverride[]

  @@map("master_value")
  @@unique([masterDefinitionId, code])
  @@index([masterDefinitionId])
  @@index([parentId])
  @@index([status])
}

// â"€â"€ 29. MasterOverride â€" company / branch level customisation â"€â"€
// scopeType: COMPANY | BRANCH
model MasterOverride {
  id            Int     @id @default(autoincrement())
  masterValueId Int
  scopeType     String  // COMPANY | BRANCH
  scopeId       Int
  customValue   String  @default("")
  isEnabled     Boolean @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  masterValue MasterValue @relation(fields: [masterValueId], references: [id], onDelete: Cascade)

  @@map("master_override")
  @@unique([masterValueId, scopeType, scopeId])
  @@index([masterValueId])
  @@index([scopeType, scopeId])
}

// â"€â"€ 30. MasterValidationRule â€" links a master to a Policy Engine rule â"€â"€
model MasterValidationRule {
  id                 Int     @id @default(autoincrement())
  masterDefinitionId Int
  policyId           Int?
  ruleName           String
  isActive           Boolean @default(true)

  definition MasterDefinition @relation(fields: [masterDefinitionId], references: [id], onDelete: Cascade)

  @@map("master_validation_rule")
  @@index([masterDefinitionId])
  @@index([policyId])
}

// â"€â"€ 31. MasterAudit â€" change trail for all master operations â"€â"€
// masterType: DEFINITION | VALUE | OVERRIDE | POLICY
model MasterAudit {
  id          Int      @id @default(autoincrement())
  masterId    Int
  masterType  String
  action      String   // CREATED | UPDATED | STATUS_CHANGED | OVERRIDE_ADDED | VALUE_IMPORTED
  oldValue    String?  @db.Text
  newValue    String?  @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  performer Employee @relation("MasterAuditPerformedBy", fields: [performedBy], references: [id])

  @@map("master_audit")
  @@index([masterId, masterType])
  @@index([performedBy])
  @@index([createdAt])
}

// â"€â"€ 32. CustomerPolicy â€" governance rules per company / customer type â"€â"€
model CustomerPolicy {
  id                     Int     @id @default(autoincrement())
  companyId              Int?
  customerType           String  @default("ALL")
  gstRequired            Boolean @default(true)
  panRequired            Boolean @default(false)
  duplicateThreshold     Int     @default(80)
  creditApprovalRequired Boolean @default(false)
  status                 String  @default("ACTIVE")
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@map("customer_policy")
  @@index([companyId])
  @@index([customerType])
  @@index([status])
}

// â"€â"€ 33. VendorPolicy â€" governance rules per company â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€â"€
model VendorPolicy {
  id                       Int     @id @default(autoincrement())
  companyId                Int?
  gstRequired              Boolean @default(true)
  panRequired              Boolean @default(false)
  bankVerificationRequired Boolean @default(false)
  approvalRequired         Boolean @default(true)
  status                   String  @default("ACTIVE")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  @@map("vendor_policy")
  @@index([companyId])
  @@index([status])
}

// ── 34. PipelineDefinition — named sales process with ordered stages ──────────
// Multiple pipelines can coexist (e.g. "Enterprise Sales", "Renewal Pipeline").
// isDefault=true pipeline is used when no pipeline is explicitly selected.
model PipelineDefinition {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  name        String
  code        String   @unique
  description String   @default("") @db.Text
  isDefault   Boolean  @default(false)
  status      String   @default("active") // active|archived
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  stages PipelineStage[]

  @@map("pipeline_definition")
  @@index([companyId])
  @@index([status])
}

// ── 35. PipelineStage — one stage inside a PipelineDefinition ────────────────
// stageCode links back to OPP_STAGES for backward compat with existing CRM.
// stageType: OPEN | WON | LOST
// mandatoryFieldsJson: JSON array of field names, e.g. ["amount","expectedClosureDate"]
model PipelineStage {
  id                  Int                @id @default(autoincrement())
  pipelineId          Int
  pipeline            PipelineDefinition @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  stageName           String
  stageCode           String
  sequence            Int
  probability         Int                @default(50)
  stageType           String             @default("OPEN") // OPEN|WON|LOST
  requiresApproval    Boolean            @default(false)
  mandatoryFieldsJson String             @default("[]") @db.Text
  entryRuleId         Int?
  exitRuleId          Int?
  status              String             @default("active")
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt

  @@map("pipeline_stage")
  @@index([pipelineId])
  @@index([pipelineId, sequence])
}

// ── 36. Territory — named geographic/segment territory ────────────────────────
model Territory {
  id          Int      @id @default(autoincrement())
  companyId   Int?
  name        String
  description String   @default("") @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rules TerritoryRule[]

  @@map("territory")
  @@index([companyId])
  @@index([status])
}

// ── 37. TerritoryRule — one condition line inside a Territory ─────────────────
// conditionJson: {field:"state",operator:"eq",value:"Tamil Nadu"}
model TerritoryRule {
  id            Int       @id @default(autoincrement())
  territoryId   Int
  territory     Territory @relation(fields: [territoryId], references: [id], onDelete: Cascade)
  conditionJson String    @db.Text
  createdAt     DateTime  @default(now())

  @@map("territory_rule")
  @@index([territoryId])
}

// ── 38. AccountAssignmentRule — priority-ordered assignment routing ────────────
// assignToType: USER | TEAM | ROLE | QUEUE
// conditionJson: {and:[{field,operator,value},...]}
model AccountAssignmentRule {
  id            Int      @id @default(autoincrement())
  name          String
  priority      Int      @default(10)
  conditionJson String   @db.Text
  assignToType  String   // USER|TEAM|ROLE|QUEUE
  assignToId    Int?
  assignToName  String   @default("")
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("account_assignment_rule")
  @@index([status, priority])
}

// ── 39. CRMAutomationRule — event-driven no-code automation ──────────────────
// event: LEAD_CREATED | LEAD_CONVERTED | OPPORTUNITY_CREATED | STAGE_CHANGED |
//        DEAL_WON | DEAL_LOST | NO_ACTIVITY | RENEWAL_DUE
// actionJson: {type:"CREATE_TASK",params:{title,daysFromNow,assignToType}}
model CRMAutomationRule {
  id            Int      @id @default(autoincrement())
  name          String
  event         String
  conditionJson String   @default("{}") @db.Text
  actionJson    String   @db.Text
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("crm_automation_rule")
  @@index([event, status])
}

// ── 40. SLARule — response / follow-up time targets ──────────────────────────
// module: CRM | SUPPORT | FINANCE
// event:  LEAD_RESPONSE | OPPORTUNITY_FOLLOW_UP | PROPOSAL_DUE | etc.
model SLARule {
  id                 Int      @id @default(autoincrement())
  module             String
  event              String
  label              String   @default("")
  durationHours      Int
  warningHours       Int      @default(0) // 0 = warn at 80% of durationHours
  escalationPolicyId Int?
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("sla_rule")
  @@index([module, event])
  @@index([status])
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 10: Enterprise Performance Management Engine
// 9 models: PerformancePeriod, KRAMetric, KRATemplate, KRATemplateItem,
// EmployeeTarget, TeamTarget, KRAAchievement, PerformanceReview, PerformanceAudit
// ─────────────────────────────────────────────────────────────────────────────

model PerformancePeriod {
  id            Int      @id @default(autoincrement())
  companyId     Int?
  name          String
  financialYear String   @default("")
  periodType    String   @default("YEARLY")
  startDate     DateTime
  endDate       DateTime
  status        String   @default("active")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  employeeTargets EmployeeTarget[]
  teamTargets     TeamTarget[]

  @@index([companyId])
  @@index([periodType])
  @@index([status])
  @@index([financialYear])
  @@map("performance_period")
}

model KRAMetric {
  id                Int      @id @default(autoincrement())
  companyId         Int?
  name              String
  code              String   @unique
  description       String   @default("") @db.Text
  metricType        String   @default("CUSTOM")
  calculationSource String   @default("MANUAL")
  formulaJson       String   @default("") @db.Text
  status            String   @default("active")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  templateItems KRATemplateItem[]
  achievements  KRAAchievement[]

  @@index([companyId])
  @@index([metricType])
  @@index([status])
  @@map("kra_metric")
}

model KRATemplate {
  id           Int      @id @default(autoincrement())
  companyId    Int?
  name         String
  description  String   @default("") @db.Text
  roleId       Int?
  departmentId Int?
  status       String   @default("draft")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  items           KRATemplateItem[]
  employeeTargets EmployeeTarget[]

  @@index([companyId])
  @@index([roleId])
  @@index([departmentId])
  @@index([status])
  @@map("kra_template")
}

model KRATemplateItem {
  id             Int         @id @default(autoincrement())
  template       KRATemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  templateId     Int
  metric         KRAMetric   @relation(fields: [metricId], references: [id], onDelete: Restrict)
  metricId       Int
  weightage      Float       @default(0)
  targetType     String      @default("AMOUNT")
  minimumTarget  Float       @default(0)
  expectedTarget Float       @default(0)
  stretchTarget  Float       @default(0)
  sortOrder      Int         @default(0)
  status         String      @default("active")

  @@index([templateId])
  @@index([metricId])
  @@map("kra_template_item")
}

model EmployeeTarget {
  id                Int               @id @default(autoincrement())
  employeeProfileId Int
  period            PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  periodId          Int
  templateId        Int?
  targetJson        String            @default("") @db.Text
  status            String            @default("active")
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  employeeProfile EmployeeProfile @relation(fields: [employeeProfileId], references: [id], onDelete: Cascade)
  template        KRATemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  achievements    KRAAchievement[]
  reviews         PerformanceReview[]

  @@index([employeeProfileId])
  @@index([periodId])
  @@index([templateId])
  @@index([status])
  @@map("employee_target")
}

model TeamTarget {
  id         Int               @id @default(autoincrement())
  teamId     Int
  period     PerformancePeriod @relation(fields: [periodId], references: [id], onDelete: Restrict)
  periodId   Int
  targetJson String            @default("") @db.Text
  status     String            @default("active")
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  @@index([teamId])
  @@index([periodId])
  @@map("team_target")
}

model KRAAchievement {
  id               Int            @id @default(autoincrement())
  employeeTarget   EmployeeTarget @relation(fields: [employeeTargetId], references: [id], onDelete: Cascade)
  employeeTargetId Int
  metric           KRAMetric      @relation(fields: [metricId], references: [id], onDelete: Restrict)
  metricId         Int
  actualValue      Float          @default(0)
  achievementPct   Float          @default(0)
  weightedScore    Float          @default(0)
  sourceReference  String         @default("")
  calculatedAt     DateTime       @default(now())
  status           String         @default("active")

  @@index([employeeTargetId])
  @@index([metricId])
  @@map("kra_achievement")
}

model PerformanceReview {
  id               Int            @id @default(autoincrement())
  employeeTarget   EmployeeTarget @relation(fields: [employeeTargetId], references: [id], onDelete: Cascade)
  employeeTargetId Int
  reviewerId       Int
  workflowRequestId Int?
  selfRating       Float          @default(0)
  managerRating    Float          @default(0)
  finalRating      Float          @default(0)
  comments         String         @default("") @db.Text
  status           String         @default("DRAFT")
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([employeeTargetId])
  @@index([reviewerId])
  @@index([status])
  @@map("performance_review")
}

model PerformanceAudit {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  action      String
  oldValue    String   @default("") @db.Text
  newValue    String   @default("") @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("performance_audit")
}

// ─────────────────────────────────────────────────────────────────────────────
// Phase 11: Communication Center
// 7 models: CommunicationEvent, NotificationChannel, NotificationTemplate,
// NotificationRule, NotificationQueue, NotificationDeliveryLog, CommunicationAudit
// ─────────────────────────────────────────────────────────────────────────────

model CommunicationEvent {
  id          Int      @id @default(autoincrement())
  module      String
  eventCode   String   @unique
  eventName   String
  description String   @default("") @db.Text
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templates NotificationTemplate[]
  rules     NotificationRule[]
  queue     NotificationQueue[]

  @@index([module])
  @@index([status])
  @@map("communication_event")
}

model NotificationChannel {
  id          Int      @id @default(autoincrement())
  channelName String
  channelCode String   @unique
  provider    String   @default("")
  status      String   @default("inactive")
  configJson  String   @default("") @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  templates NotificationTemplate[]

  @@index([status])
  @@map("notification_channel")
}

model NotificationTemplate {
  id            Int                  @id @default(autoincrement())
  event         CommunicationEvent?  @relation(fields: [eventId], references: [id], onDelete: SetNull)
  eventId       Int?
  channel       NotificationChannel? @relation(fields: [channelId], references: [id], onDelete: SetNull)
  channelId     Int?
  templateName  String
  subject       String               @default("")
  body          String               @default("") @db.Text
  variablesJson String               @default("") @db.Text
  status        String               @default("active")
  createdAt     DateTime             @default(now())
  updatedAt     DateTime             @updatedAt

  queue NotificationQueue[]

  @@index([eventId])
  @@index([channelId])
  @@index([status])
  @@map("notification_template")
}

model NotificationRule {
  id            Int                @id @default(autoincrement())
  event         CommunicationEvent @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventId       Int
  policyId      Int?
  ruleName      String
  conditionJson String             @default("") @db.Text
  recipientJson String             @default("") @db.Text
  channelJson   String             @default("") @db.Text
  frequencyJson String             @default("") @db.Text
  status        String             @default("active")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([eventId])
  @@index([status])
  @@map("notification_rule")
}

model NotificationQueue {
  id              Int                  @id @default(autoincrement())
  event           CommunicationEvent   @relation(fields: [eventId], references: [id], onDelete: Restrict)
  eventId         Int
  template        NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  templateId      Int?
  recipientUserId Int?
  channel         String               @default("IN_APP")
  payloadJson     String               @default("") @db.Text
  status          String               @default("PENDING")
  scheduledAt     DateTime?
  sentAt          DateTime?
  failureReason   String               @default("") @db.Text
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  deliveryLogs NotificationDeliveryLog[]

  @@index([eventId])
  @@index([recipientUserId])
  @@index([status])
  @@index([channel])
  @@index([scheduledAt])
  @@map("notification_queue")
}

model NotificationDeliveryLog {
  id           Int               @id @default(autoincrement())
  queue        NotificationQueue @relation(fields: [queueId], references: [id], onDelete: Cascade)
  queueId      Int
  channel      String
  provider     String            @default("")
  status       String            @default("PENDING")
  responseJson String            @default("") @db.Text
  createdAt    DateTime          @default(now())

  @@index([queueId])
  @@index([status])
  @@index([channel])
  @@map("notification_delivery_log")
}

model CommunicationAudit {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  action      String
  oldValue    String   @default("") @db.Text
  newValue    String   @default("") @db.Text
  performedBy Int
  createdAt   DateTime @default(now())

  @@index([entityType, entityId])
  @@index([performedBy])
  @@index([createdAt])
  @@map("communication_audit")
}

// ── Phase 12: Integration Center ─────────────────────────────────────────────

model IntegrationProvider {
  id          Int      @id @default(autoincrement())
  name        String
  code        String   @unique
  category    String   @default("CUSTOM_API")
  description String   @default("") @db.Text
  logoUrl     String?
  docsUrl     String?
  status      String   @default("INACTIVE")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  connections IntegrationConnection[]

  @@index([category])
  @@index([status])
  @@map("integration_provider")
}

model IntegrationConnection {
  id             Int                  @id @default(autoincrement())
  provider       IntegrationProvider  @relation(fields: [providerId], references: [id], onDelete: Cascade)
  providerId     Int
  companyId      Int?
  connectionName String
  authType       String               @default("ENV_REFERENCE")
  configJson     String               @default("{}") @db.Text
  secretRef      String?
  status         String               @default("INACTIVE")
  lastTestedAt   DateTime?
  lastTestStatus String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  usageRules IntegrationUsageRule[]
  logs       IntegrationLog[]

  @@index([providerId])
  @@index([companyId])
  @@index([status])
  @@map("integration_connection")
}

model IntegrationUsageRule {
  id           Int                   @id @default(autoincrement())
  connection   IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  connectionId Int
  module       String
  event        String
  policyId     Int?
  status       String                @default("ACTIVE")
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([connectionId])
  @@index([module])
  @@map("integration_usage_rule")
}

model IntegrationLog {
  id                  Int                   @id @default(autoincrement())
  connection          IntegrationConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)
  connectionId        Int
  module              String                @default("")
  event               String                @default("")
  requestSummaryJson  String                @default("{}") @db.Text
  responseSummaryJson String                @default("{}") @db.Text
  status              String                @default("SUCCESS")
  errorMessage        String?               @db.Text
  createdAt           DateTime              @default(now())

  @@index([connectionId])
  @@index([status])
  @@index([createdAt])
  @@map("integration_log")
}

model APIKeyReference {
  id                      Int      @id @default(autoincrement())
  companyId               Int?
  name                    String
  keyType                 String   @default("API_KEY")
  environmentVariableName String   @unique
  description             String   @default("") @db.Text
  status                  String   @default("ACTIVE")
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@index([companyId])
  @@index([status])
  @@map("api_key_reference")
}

// ── Phase 13: Security Center ─────────────────────────────────────────────────

model SecurityPolicy {
  id         Int      @id @default(autoincrement())
  companyId  Int?
  policyName String
  policyType String   @default("PASSWORD")
  policyJson String   @default("{}") @db.Text
  status     String   @default("DRAFT")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([companyId])
  @@index([policyType])
  @@index([status])
  @@map("security_policy")
}

model PasswordPolicy {
