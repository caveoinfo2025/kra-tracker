# -----------------------------------------------------------------------------
# Playwright test environment
# Copy this file to `.env.test` and fill in the values for your isolated test
# environment only. Never use production credentials here.
# -----------------------------------------------------------------------------

# Dedicated test database only. Do not reuse development, staging, or production.
# Use a database name that clearly includes `test`, `e2e`, or `playwright`.
DATABASE_URL="mysql://test_user:test_password@127.0.0.1:3306/kra_tracker_e2e_test"

# Optional explicit DB_* values if your environment uses them instead of
# DATABASE_URL. Keep these pointed at the same isolated test database.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=test_user
DB_PASSWORD=test_password
DB_NAME=kra_tracker_e2e_test

# Required when using a non-local dedicated test database host. Leave as `0`
# for local databases.
TEST_DATABASE_CONFIRMED=0

# Base URL used by Playwright helpers.
PLAYWRIGHT_BASE_URL=http://localhost:3000

# This app uses Microsoft OAuth in production and a dev quick-login flow in
# development. For local functional tests, prefer `dev-cookie`.
PLAYWRIGHT_LOGIN_MODE=dev-cookie

# Role-based Playwright login helper values.
# Use employee ids from your dedicated test database.
# For this repo's local dev seed, manager often defaults to 4 and employee to 5.
# Explicit values here always override the helper fallbacks.
PLAYWRIGHT_ADMIN_EMPLOYEE_ID=
PLAYWRIGHT_MANAGER_EMPLOYEE_ID=
PLAYWRIGHT_EMPLOYEE_EMPLOYEE_ID=

# Optional placeholders for future non-dev login automation.
# Leave blank unless you add a test-safe credential flow.
PLAYWRIGHT_ADMIN_EMAIL=
PLAYWRIGHT_ADMIN_PASSWORD=
PLAYWRIGHT_MANAGER_EMAIL=
PLAYWRIGHT_MANAGER_PASSWORD=
PLAYWRIGHT_EMPLOYEE_EMAIL=
PLAYWRIGHT_EMPLOYEE_PASSWORD=
