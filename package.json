{
  "name": "kra-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && cross-env RAYON_NUM_THREADS=1 next build",
    "build:test": "node scripts/run-build-test.mjs",
    "start": "next start",
    "lint": "eslint",
    "playwright:install": "set PLAYWRIGHT_BROWSERS_PATH=.playwright-browsers&& playwright install chromium",
    "test:e2e": "node scripts/run-playwright.mjs",
    "test:e2e:smoke": "node scripts/run-playwright.mjs tests/smoke/homepage-login.spec.ts --project=Desktop Chrome",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:test:check": "node scripts/check-test-env.mjs",
    "db:test:migrate": "node scripts/run-prisma-test.mjs migrate deploy",
    "db:test:push": "node scripts/run-prisma-test.mjs db push",
    "db:test:seed": "node scripts/run-prisma-test.mjs db seed",
    "deploy:uat": "node scripts/deploy-uat.mjs",
    "db:uat:copy": "node scripts/db-copy-prod-to-uat.mjs"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/postcss": "^4",
    "better-sqlite3": "^12.10.0",
    "lucide-react": "^1.16.0",
    "mariadb": "^3.5.2",
    "next": "16.2.6",
    "next-auth": "^5.0.0-beta.31",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwindcss": "^4",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "cross-env": "^10.1.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "sharp": "^0.34.5",
    "ssh2": "^1.17.0",
    "typescript": "^5"
  }
}
