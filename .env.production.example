# ─────────────────────────────────────────────────────────────────────────────
# KRA Tracker — Production Environment Variables
# Copy this file, fill in real values, and paste into Hostinger's
# "Environment Variables" panel (Websites → your site → Node.js → Env vars).
# NEVER commit the filled-in file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite file path on the Hostinger server.
# Hostinger stores your app at: /home/<user>/htdocs/<domain>/
# The prisma/ sub-directory will be created on first deploy.
DATABASE_URL="file:./prisma/prod.db"

# ── Microsoft / Azure AD (copy from Azure Portal → App Registrations) ─────────
AZURE_AD_CLIENT_ID="your-client-id-here"
AZURE_AD_CLIENT_SECRET="your-client-secret-here"
AZURE_AD_TENANT_ID="your-tenant-id-here"

# ── NextAuth ──────────────────────────────────────────────────────────────────
# AUTH_SECRET: run `openssl rand -base64 32` to generate a strong secret.
AUTH_SECRET="replace-with-a-strong-random-secret"

# AUTH_URL must match the exact public URL of the deployed app (no trailing slash).
AUTH_URL="https://caveoinfosystems.com"

# ── Node ──────────────────────────────────────────────────────────────────────
NODE_ENV="production"
PORT=3000
